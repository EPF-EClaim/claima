<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <SelectDialog
        id="claimTypeFilterDialog"
        title="{i18n>myclaimstatus_filter}"
        multiSelect="true"
        confirm=".onFilterConfirm"
        cancel=".onFilterCancel"
        search=".onFilterSearch"
        items="{
            path: 'filterModel>/items'
        }">
        <StandardListItem title="{filterModel>title}" />
    </SelectDialog>
</core:FragmentDefinition>