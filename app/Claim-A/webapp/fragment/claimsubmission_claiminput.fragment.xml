<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.ui.layout.form"
	xmlns:u="sap.ui.unified"
    xmlns:mdc="sap.ui.mdc"
    xmlns:mdcvh="sap.ui.mdc.valuehelp"
    xmlns:mdcvhcnt="sap.ui.mdc.valuehelp.content"
>
    <Dialog id="dialog_claiminput" title="{i18n>dialog_claiminput}" contentWidth="50em">

            <!-- Form Layout -->
            <f:SimpleForm
                id="idClaimSubmissionHeaderInput"
                editable="true"
                layout="ResponsiveGridLayout"
                labelSpanXL="4"
                labelSpanL="4"
                labelSpanM="4"
                labelSpanS="12"
                adjustLabelSpan="false"
                emptySpanXL="2"
                emptySpanL="2"
                emptySpanM="2"
                emptySpanS="0"
                columnsM="1"
                columnsL="1"
                columnsXL="1"
                singleContainerFullSize="false" >
                <f:content>
                    <!-- Report Purpose -->
                    <Label text="{i18n>label_claiminput_purpose}" />
                    <Input
                        id="input_claiminput_purpose"
                        value="{claimsubmission_input>/claim_header/purpose}"
                        required="true"
                    />
                    
                    <!-- Claim Type -->
                    <Label text="{i18n>label_claiminput_claimtype}" />
                    <Text
                        id="text_claiminput_claimtype"
                        text="{claimsubmission_input>/claim_header/descr/claim_type_id}"
                    />
                    
                    <!-- Submission Type -->
                    <Label text="{i18n>label_claiminput_subtype}" />
                    <Text
                        id="text_claiminput_subtype"
                        text="{claimsubmission_input>/claim_header/descr/submission_type}"
                        visible="false"
                    />

                    <!-- Course Code -->
                    <Label text="{i18n>label_claiminput_course_code}" />
                    <Text
                        id="text_claiminput_course_code"
                        text="{claimsubmission_input>/claim_header/course_code} - {claimsubmission_input>/claim_header/descr/course_code}"
                        visible="{= ${claimsubmission_input>/claim_header/course_code} !== null}"
                    />

                    <!-- Session Number -->
                    <Label text="{i18n>label_claiminput_session_number}" />
                    <Text
                        id="text_claiminput_session_number"
                        text="{claimsubmission_input>/claim_header/session_number}"
                        visible="{= ${claimsubmission_input>/claim_header/session_number} !== null}"
                    />

                    <!-- Pre-Approval Request -->
                    <Label text="{i18n>label_claiminput_preapprovalreq}" />
                    <Text
                        id="text_claiminput_preapprovalreq"
                        text="{claimsubmission_input>/claim_header/request_id} {claimsubmission_input>/claim_header/descr/request_id}"
                        visible="{= ${claimsubmission_input>/claimtype/requestform/request_id} !== null &amp;&amp;
                                !${claimsubmission_input>/req_emailapprove} }"
                    />

                    <!-- Pre-Approved Amount (MYR) -->
                    <Label text="{i18n>label_claiminput_amtapproved}" />
                    <Text
                        id="text_claiminput_amtapproved"
                        text="{claimsubmission_input>/claim_header/preapproved_amount}"
                        visible="{= ${claimsubmission_input>/claimtype/requestform/preapproval_amount} !== null &amp;&amp;
                                !${claimsubmission_input>/req_emailapprove} }"
                    />

                    <!-- Trip Start Date -->
                    <Label text="{i18n>label_claiminput_tripstartdate}" />
                    <DatePicker
                        id="datepicker_claiminput_tripstartdate"
                        value="{claimsubmission_input>/claim_header/trip_start_date}"
                        editable="{= ( ${claimsubmission_input>/claim_header/submission_type} !== ${constant>/SubmissionType/PRE_APPROVE} &amp;&amp;
                                    ${claimsubmission_input>/claim_header/submission_type} !== ${constant>/SubmissionType/CASH_REPAYMENT} &amp;&amp;
                                    ${claimsubmission_input>/claim_header/submission_type} !== ${constant>/SubmissionType/CURR_SUBSIDY} ) ||
                                
                                ( ${claimsubmission_input>/req_emailapprove} &amp;&amp;
                                    ( !Object.values(${constant>/ClaimTypeKursus}).includes(${claimsubmission_input>/claimtype/type}) ||
                                        ${claimsubmission_input>/claimtype/course_code/start_date} === null ))
                        }"
                        required="true"
                        displayFormat="dd-MMM-yyyy"
                        />

                    <!-- Trip End Date -->
                    <Label text="{i18n>label_claiminput_tripenddate}" />
                    <DatePicker
                        id="datepicker_claiminput_tripenddate"
                        value="{claimsubmission_input>/claim_header/trip_end_date}"
                        editable="{= ( ${claimsubmission_input>/claim_header/submission_type} !== ${constant>/SubmissionType/PRE_APPROVE} &amp;&amp;
                                        ${claimsubmission_input>/claim_header/submission_type} !== ${constant>/SubmissionType/CASH_REPAYMENT} &amp;&amp;
                                        ${claimsubmission_input>/claim_header/submission_type} !== ${constant>/SubmissionType/CURR_SUBSIDY} ) ||

                                ( ${claimsubmission_input>/req_emailapprove} &amp;&amp;
                                    ( !Object.values(${constant>/ClaimTypeKursus}).includes(${claimsubmission_input>/claimtype/type}) ||
                                        ${claimsubmission_input>/claimtype/course_code/end_date} === null ))
                        }"
                        required="true"
                        displayFormat="dd-MMM-yyyy"
                        />

                    <!-- Event Start Date -->
                    <Label text="{i18n>label_claiminput_eventstartdate}" />
                    <DatePicker
                        id="datepicker_claiminput_eventstartdate"
                        value="{claimsubmission_input>/claim_header/event_start_date}"
                        editable="{= ( ${claimsubmission_input>/claim_header/submission_type} !== ${constant>/SubmissionType/PRE_APPROVE} &amp;&amp;
                                        ${claimsubmission_input>/claim_header/submission_type} !== ${constant>/SubmissionType/CASH_REPAYMENT} &amp;&amp;
                                        ${claimsubmission_input>/claim_header/submission_type} !== ${constant>/SubmissionType/CURR_SUBSIDY} ) ||
                                ${claimsubmission_input>/req_emailapprove} }"
                        displayFormat="dd-MMM-yyyy"
                        />

                    <!-- Event End Date -->
                    <Label text="{i18n>label_claiminput_eventenddate}" />
                    <DatePicker
                        id="datepicker_claiminput_eventenddate"
                        value="{claimsubmission_input>/claim_header/event_end_date}"
                        editable="{= ( ${claimsubmission_input>/claim_header/submission_type} !== ${constant>/SubmissionType/PRE_APPROVE} &amp;&amp;
                                        ${claimsubmission_input>/claim_header/submission_type} !== ${constant>/SubmissionType/CASH_REPAYMENT} &amp;&amp;
                                        ${claimsubmission_input>/claim_header/submission_type} !== ${constant>/SubmissionType/CURR_SUBSIDY} ) ||
                                ${claimsubmission_input>/req_emailapprove} }"
                        displayFormat="dd-MMM-yyyy"
                        />

                     <!-- Loan Scheme -->
                    <Label text="{i18n>label_claiminput_loan_scheme}" />
                    <Select
                        id="select_claiminput_loan_scheme"
                        forceSelection="false"
                        selectedKey="{claimsubmission_input>/claim_header/housing_loan_scheme}"
                        items="{
                            path: 'employee>/ZHOUSING_LOAN_SCHEME',
                            sorter: [
                                { path: 'HOUSING_LOAN_SCHEME_ID' },
                                { path: 'HOUSING_LOAN_SCHEME_DESC' }
                            ]
                        }"
                        visible="{= ${claimsubmission_input>/claim_header/claim_type_id} === ${constant>/ClaimType/ELAUN_PINDAH} }"
                        change="onSelect_ClaimHeader"
                        liveChange="onSelect_ClaimHeader"
                    >
                        <core:Item key="{employee>HOUSING_LOAN_SCHEME_ID}" text="{employee>HOUSING_LOAN_SCHEME_DESC}" />
                    </Select>

                     <!-- Lender Name -->
                    <Label text="{i18n>label_claiminput_lender_name}" />
                    <Select
                        id="select_claiminput_lender_name"
                        forceSelection="false"
                        selectedKey="{claimsubmission_input>/claim_header/lender_name}"
                        items="{
                            path: 'employee>/ZLENDER_NAME',
                            sorter: [
                                { path: 'LENDER_ID' },
                                { path: 'LENDER_NAME' }
                            ]
                        }"
                        visible="{= ${claimsubmission_input>/claim_header/claim_type_id} === ${constant>/ClaimType/ELAUN_PINDAH} }"
                        change="onSelect_ClaimHeader"
                        liveChange="onSelect_ClaimHeader"
                    >
                        <core:Item key="{employee>LENDER_ID}" text="{employee>LENDER_NAME}" />
                    </Select>

                    <!-- Move-In Date -->
                    <Label text="{i18n>label_claiminput_move_in_date}" />
                    <DatePicker
                        id="datepicker_claiminput_move_in_date"
                        value="{claimsubmission_input>/claim_header/move_in_date}"
                        visible="{= ${claimsubmission_input>/claim_header/claim_type_id} === ${constant>/ClaimType/ELAUN_PINDAH} }"
                        required="{= ${claimsubmission_input>/claim_header/claim_type_id} === ${constant>/ClaimType/ELAUN_PINDAH} }"
                        displayFormat="dd-MMM-yyyy"
                    />

                    <!-- Location -->
                    <Label text="{i18n>label_claiminput_location}" />
                    <Input
                        id="input_claiminput_location"
                        value="{claimsubmission_input>/claim_header/location}"
                    />

                    <!-- Alternate Cost Center -->
                    <Label text="{i18n>label_claiminput_altcc}" />
                    <mdc:Field
                        id="field_claiminput_altcc"
                        value="{claimsubmission_input>/claim_header/alternate_cost_center}"
                        additionalValue="{claimsubmission_input>/claim_header/descr/alternate_cost_center}"
                        editMode="Editable"
                        display="ValueDescription"
                        visible="{= ${claimsubmission_input>/claimtype/cost_center} === null &amp;&amp;

                            (${claimsubmission_input>/claimtype/requestform/alternate_cost_center} === null ||
                                ${claimsubmission_input>/req_emailapprove})
                        }"
                        valueHelp="valuehelp_claiminput_altcc"
                    />
                    
                    <!-- Alternate Cost Center (Claim Type/Pre-Approval) -->
                    <Label text="{i18n>label_claiminput_altcc}" />
                    <Input
                        id="input_claiminput_altcc"
                        value="{claimsubmission_input>/claim_header/alternate_cost_center} ({claimsubmission_input>/claim_header/descr/alternate_cost_center})"
                        editable="false"
                        visible="{= ${claimsubmission_input>/claimtype/cost_center} !== null ||

                            (${claimsubmission_input>/claimtype/requestform/alternate_cost_center} !== null &amp;&amp;
                                !${claimsubmission_input>/req_emailapprove})
                        }"
                    />
                    
                    <!-- Attachment Email Approval -->
                    <Label text="{i18n>label_claiminput_attachment}" />
                    <u:FileUploader
                        id="fileuploader_claiminput_attachment"
                        name="fileUploaderClaimInputAttachment"
                        placeholder="{i18n>text_claiminput_attachment_filetypes}"
                        uploadUrl="SuccessFactors_API/odata/v2/Attachment"
                        change="onChange_ClaimInput_Attachment"
                        uploadComplete="onUploadComplete_ClaimInput_Attachment"
                        maximumFileSize='5.0'
                        fileSizeExceed="onFileSizeExceed_ClaimInput_Attachment"
                        mimeType="application/pdf,image/png,image/jpeg"
                        typeMissmatch="onTypeMissmatch_ClaimInput_Attachment"
                        multiple="false"
                        style="Emphasized"
                        visible="{= ( ${claimsubmission_input>/claim_header/submission_type} === ${constant>/SubmissionType/PRE_APPROVE} ||
                                        ${claimsubmission_input>/claim_header/submission_type} === ${constant>/SubmissionType/CASH_REPAYMENT} ||
                                        ${claimsubmission_input>/claim_header/submission_type} === ${constant>/SubmissionType/CURR_SUBSIDY} ) }"
                        required="{= ( ${claimsubmission_input>/claim_header/submission_type} === ${constant>/SubmissionType/PRE_APPROVE} ||
                                        ${claimsubmission_input>/claim_header/submission_type} === ${constant>/SubmissionType/CASH_REPAYMENT} ||
                                        ${claimsubmission_input>/claim_header/submission_type} === ${constant>/SubmissionType/CURR_SUBSIDY} ) &amp;&amp;
                                        
                                        ${claimsubmission_input>/req_emailapprove} }"
                    >
                    </u:FileUploader>

                    <!-- Comment -->
                    <Label text="{i18n>label_claiminput_comment}" />
                    <Input
                        id="input_claiminput_comment"
                        value="{claimsubmission_input>/claim_header/comment}"
                        required="true"
                    />
                </f:content>
                <f:dependents>
                    <mdc:ValueHelp
                        id="valuehelp_claiminput_altcc"
                        delegate='\{
                            "name": "claima/utils/ValueHelpDelegate_altcc",
                            "payload": \{
                                "searchKeys": ["COST_CENTER_ID", "COST_CENTER_DESC"],
                                "columns": [
                                    "\{i18n>valuehelp_claiminput_altcc_col_id\}",
                                    "\{i18n>valuehelp_claiminput_altcc_col_name\}"
                                ]
                            \}
                        \}'
                    >
                        <mdc:typeahead>
                            <mdcvh:Popover id="valuehelp_claiminput_altcc_pop">
                                <mdcvhcnt:MTable id="valuehelp_claiminput_altcc_pop_MTable"
                                    keyPath="COST_CENTER_ID"
                                    descriptionPath="COST_CENTER_DESC"
                                    caseSensitive="false"
                                    useAsValueHelp="false">
                                    <!-- create table via delegate-->
                                </mdcvhcnt:MTable>
                            </mdcvh:Popover>
                        </mdc:typeahead>
                        <mdc:dialog>
                            <mdcvh:Dialog
                                id="valuehelp_claiminput_altcc_dialog"
                                title="{i18n>valuehelp_claiminput_altcc}"
                            >
                                <mdcvhcnt:MTable
                                    id="valuehelp_claiminput_altcc_dialog_MTable"
                                    keyPath="COST_CENTER_ID"
                                    descriptionPath="COST_CENTER_DESC"
                                    caseSensitive="false">
                                    <!-- create table via delegate-->
                                </mdcvhcnt:MTable>
                            </mdcvh:Dialog>
                        </mdc:dialog>
                    </mdc:ValueHelp>
                </f:dependents>
            </f:SimpleForm>
     
		<buttons>
            <!-- Claim Submission -->
            <Button
                id="button_claiminput_claimsubmission"
                press="onAction_ClaimInput"
                text="{i18n>button_claiminput_claimsubmission}"
				type="Emphasized"
            />

            <!-- Cancel -->
			<Button
                id="button_claiminput_cancel"
                press="onCancel_ClaimInput"
                text="{i18n>button_claiminput_cancel}"
            />
        </buttons>     
    </Dialog>
</core:FragmentDefinition>
