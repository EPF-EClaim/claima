<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.ui.layout.form"
>
    <Dialog id="dialog_claimprocess" title="{i18n>dialog_claimprocess}" contentWidth="50em">

            <!-- Form Layout -->
            <f:SimpleForm
                editable="true"
                layout="ResponsiveGridLayout"
                labelSpanXL="4"
                labelSpanL="4"
                labelSpanM="4"
                labelSpanS="12"
                adjustLabelSpan="false"
                emptySpanXL="2"
                emptySpanL="2"
                emptySpanM="2"
                emptySpanS="0"
                columnsM="1"
                columnsL="1"
                columnsXL="1"
                singleContainerFullSize="false" >
                <f:content>
                    <!-- Claim Type -->
                    <Label text="{i18n>label_claimprocess_claimtype}" />
                    <ComboBox
                        id="select_claimprocess_claimtype"
                        selectedKey="{claimsubmission_input>/claimtype/type}"
                        items="{
                            path: 'employee>/ZCLAIM_TYPE',
                            sorter: [
                                { path: 'CLAIM_TYPE_DESC' },
                                { path: 'CLAIM_TYPE_ID' }
                            ],
                            parameters: {
                                $select: 'COST_CENTER,COST_CENTER_DESC'
                            }
                        }"
                        selectionChange="onSelect_ClaimProcess_ClaimType"
                    >
                        <core:Item key="{employee>CLAIM_TYPE_ID}" text="{employee>CLAIM_TYPE_DESC}" />
                    </ComboBox>

                    <!-- Claim Item -->
                    <Label text="{i18n>label_claimprocess_claimitem}" />
                    <ComboBox
                        id="select_claimprocess_claimitem"
                        selectedKey="{claimsubmission_input>/claimtype/item}"
                        items="{
                            path: 'employee>/ZCLAIM_TYPE_ITEM',
                            sorter: [
                                { path: 'CLAIM_TYPE_ITEM_DESC' },
                                { path: 'CLAIM_TYPE_ITEM_ID' }
                            ],
                            parameters: {
                                $expand: 'ZSUBMISSION_TYPE',
                                $select: 'SUBMISSION_TYPE,ZSUBMISSION_TYPE/SUBMISSION_TYPE_DESC'
                            }
                        }"
                        editable="{= ${claimsubmission_input>/claimtype/type} !== null }"
                        selectionChange="onSelect_ClaimProcess_ClaimItem"
                    >
                        <core:Item key="{employee>CLAIM_TYPE_ITEM_ID}" text="{employee>CLAIM_TYPE_ITEM_DESC}" />
                    </ComboBox>

                    <!-- Category -->
                    <Label text="{i18n>label_claimprocess_category}" />
                    <Input
                        id="input_claimprocess_category"
                        value="{claimsubmission_input>/claimtype/descr/category}"
                        editable="false"
                    />

                    <!-- Select Course Code -->
                    <Label text="{i18n>label_claimprocess_coursecode}" />
                    <Select
                        id="select_claimprocess_course_code"
                        forceSelection="false"
                        selectedKey="{claimsubmission_input>/claimtype/course_code/course_id}"
                        items="{
                            path: 'employee_view>/ZCLM_COURSE_VIEW',
                            sorter: [
                                { path: 'COURSE_ID' },
                                { path: 'COURSE_DESC' }
                            ]
                        }"
                        visible="{= Object.values(${constant>/ClaimTypeKursus}).includes(${claimsubmission_input>/claimtype/type}) &amp;&amp;
                            ${claimsubmission_input>/claimtype/item} !== null
                        }"
                        change="onSelect_ClaimProcess_CourseCode"
                        liveChange="onSelect_ClaimProcess_CourseCode"
                    >
                        <core:Item key="{employee_view>COURSE_ID}" text="{employee_view>COURSE_ID} - {employee_view>COURSE_DESC}" />
                    </Select>

                    <!-- Select Session Number -->
                    <Label text="{i18n>label_claimprocess_session_number}" />
                    <Select
                        id="select_claimprocess_session_number"
                        forceSelection="false"
                        selectedKey="{claimsubmission_input>/claimtype/course_code/session_number}"
                        items="{
                            path: 'employee>/ZTRAIN_COURSE_PART',
                            sorter: [{ path: 'SESSION_NUMBER' }],
                            parameters: { $select: 'START_DATE,END_DATE' }
                        }"
                        editable="{= ${claimsubmission_input>/claimtype/course_code/course_id} !== null
                        }"
                        visible="{= Object.values(${constant>/ClaimTypeKursus}).includes(${claimsubmission_input>/claimtype/type}) &amp;&amp;
                            ${claimsubmission_input>/claimtype/item} !== null
                        }"
                        change="onSelect_ClaimProcess_SessionNumber"
                        liveChange="onSelect_ClaimProcess_SessionNumber"
                    >
                        <core:Item key="{employee>SESSION_NUMBER}" text="{employee>SESSION_NUMBER}" />
                    </Select>

                    <!-- Select Request Form (Pre-Approval) -->
                    <Label text="{i18n>label_claimprocess_requestform}" />
                    <Select
                        id="select_claimprocess_requestform"
                        forceSelection="false"
                        selectedKey="{claimsubmission_input>/claimtype/requestform/request_id}"
                        items="{
                            path: 'employee>/ZREQUEST_HEADER',
                            sorter: [{ path: 'REQUEST_ID' }],
                            parameters: {
                                $expand: 'COSTCENTER',
                                $select: 'EVENT_START_DATE,EVENT_END_DATE,ALTERNATE_COST_CENTER,PREAPPROVAL_AMOUNT,CASH_ADVANCE,COSTCENTER/COST_CENTER_DESC,TRANSFER_MODE_ID,TRAVEL_ALONE_FAMILY,TRAVEL_FAMILY_NOW_LATER'
                            }
                        }"
                        editable="{= !${claimsubmission_input>/req_emailapprove} }"
                        visible="{= ( ${claimsubmission_input>/claimtype/category} === ${constant>/SubmissionType/PRE_APPROVE} ||
                                        ${claimsubmission_input>/claimtype/category} === ${constant>/SubmissionType/CASH_REPAYMENT} ||
                                        ${claimsubmission_input>/claimtype/category} === ${constant>/SubmissionType/CURR_SUBSIDY} ) }"
                        change="onSelect_ClaimProcess_RequestForm"
                        liveChange="onSelect_ClaimProcess_RequestForm"
                    >
                        <core:Item key="{employee>REQUEST_ID}" text="{employee>REQUEST_ID} {employee>OBJECTIVE_PURPOSE} ({employee>TRIP_START_DATE} – {employee>TRIP_END_DATE})" />
                    </Select>

                    <!-- Email Approval -->
                    <Label text="{i18n>label_claimprocess_req_emailapprove}" />
                    <Switch
                        id="switch_claimprocess_req_emailapprove"
                        state="{claimsubmission_input>/req_emailapprove}"
                        customTextOn="{i18n>switch_claimprocess_req_emailapprove_yes}"
                        customTextOff="{i18n>switch_claimprocess_req_emailapprove_no}"
                        visible="{= ( ${claimsubmission_input>/claimtype/category} === ${constant>/SubmissionType/PRE_APPROVE} ||
                                        ${claimsubmission_input>/claimtype/category} === ${constant>/SubmissionType/CASH_REPAYMENT} ||
                                        ${claimsubmission_input>/claimtype/category} === ${constant>/SubmissionType/CURR_SUBSIDY} ) }"
                        change="onSwitch_ClaimProcess_Req_EmailApprove"
                    >
                        <layoutData>
                            <FlexItemData growFactor="1" />
                        </layoutData>
                    </Switch>
                </f:content>
            </f:SimpleForm>
     
		<buttons>
            <!-- Create Pre-Approval Request -->
            <Button
                id="button_claimprocess_preapproval"
                press="onPreApproval_ClaimProcess"
                text="{i18n>button_claimprocess_preapproval}"
                enabled="{= ( ${claimsubmission_input>/claimtype/category} === ${constant>/SubmissionType/PRE_APPROVE} ||
                                ${claimsubmission_input>/claimtype/category} === ${constant>/SubmissionType/CASH_REPAYMENT} ||
                                ${claimsubmission_input>/claimtype/category} === ${constant>/SubmissionType/CURR_SUBSIDY} ) &amp;&amp;
                                !${claimsubmission_input>/claimtype/requestform/request_id} }"
            />

            <!-- Start Claim -->
            <Button
                id="button_claimprocess_startclaim"
                press="onStartClaim_ClaimProcess"
                text="{i18n>button_claimprocess_startclaim}"
                enabled="{= ${claimsubmission_input>/claimtype/type} !== null &amp;&amp;
                            ${claimsubmission_input>/claimtype/item} !== null &amp;&amp;

                    ( !Object.values(${constant>/ClaimTypeKursus}).includes(${claimsubmission_input>/claimtype/type}) ||
                        ( ${claimsubmission_input>/claimtype/course_code/course_id} !== null &amp;&amp; ${claimsubmission_input>/claimtype/course_code/session_number} !== null )) &amp;&amp;

                    ( ( ${claimsubmission_input>/claimtype/category} !== ${constant>/SubmissionType/PRE_APPROVE} &amp;&amp;
                        ${claimsubmission_input>/claimtype/category} !== ${constant>/SubmissionType/CASH_REPAYMENT} &amp;&amp;
                        ${claimsubmission_input>/claimtype/category} !== ${constant>/SubmissionType/CURR_SUBSIDY} ) ||
                            ${claimsubmission_input>/req_emailapprove} ||
                                ${claimsubmission_input>/claimtype/requestform/request_id} !== null)
                }"
            />

            <!-- Cancel -->
			<Button
                id="button_claimprocess_cancel"
                press="onCancel_ClaimProcess"
                text="{i18n>button_claimprocess_cancel}"
            />
        </buttons>     
    </Dialog>
</core:FragmentDefinition>
