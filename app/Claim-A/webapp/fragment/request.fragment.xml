<core:FragmentDefinition 
	xmlns:unified="sap.ui.unified" 
	xmlns:l="sap.ui.layout" 
	xmlns:core="sap.ui.core" 
	xmlns:mvc="sap.ui.core.mvc" 
	xmlns="sap.m" 
	xmlns:f="sap.ui.layout.form" 
	xmlns:mdc="sap.ui.mdc"
    xmlns:mdcvh="sap.ui.mdc.valuehelp"
    xmlns:mdcvhcnt="sap.ui.mdc.valuehelp.content">
	<Dialog title="{i18n>req_po_title}" contentWidth="50%" class="requestDialog">
		<f:SimpleForm 
            id="req_create_form"
			editable="true"
			layout="ResponsiveGridLayout"
			labelSpanXL="4"
			labelSpanL="3"
			labelSpanM="4"
			labelSpanS="12"
			adjustLabelSpan="false"
			emptySpanXL="0"
			emptySpanL="4"
			emptySpanM="0"
			emptySpanS="0"
			columnsXL="2"
			columnsL="1"
			columnsM="1" >
			<f:content>
				<Label text="{i18n>req_purpose}" />
				<Input value="{reqDialog>/purpose}" required="true"/>

				<Label text="{i18n>req_rtype}" />
				<Select 
						id="req_reqtype"
						selectedKey="{reqDialog>/reqtype}" 
						required="true" 
						forceSelection="false"
						items="{
							path: 'employee>/ZREQUEST_TYPE',
							sorter: { path: 'REQUEST_TYPE_ID', descending: false }
						}"
						change=".getFieldVisibility_ReqType">
					<items>
						<core:Item 
							key="{employee>REQUEST_TYPE_ID}" 
							text="{employee>REQUEST_TYPE_DESC}" />
					</items>
				</Select>

				<Label text="{i18n>req_claimtype}" />
				<Select selectedKey="{reqDialog>/claimtype}"
						id="req_claimtype" 
						required="true" 
						forceSelection="false"
						change=".Utility.onDefaultCostCenterDetermination"
						items="{path: 'claim_type_list>/types',
								sorter: { path: 'CLAIM_TYPE_ID', descending: false }}">
					<items>
						<core:Item key="{claim_type_list>CLAIM_TYPE_ID}" 
								text="{claim_type_list>CLAIM_TYPE_DESC}" />
					</items>
				</Select>

				<Label text="{i18n>req_transfer_mode}" />
				<Select 
                    id="req_transfermode"
					selectedKey="{reqDialog>/transfermode}" 
					required="true" 
					forceSelection="false"
					visible="false"
					items="{path: 'employee>/ZTRANSFER_MODE',
							sorter: { path: 'TRANSFER_MODE_ID', descending: false }}">
					<items>
						<core:Item key="{employee>TRANSFER_MODE_ID}" 
								text="{employee>TRANSFER_MODE_DESC}" />
					</items>
				</Select>

			    <Label text="{i18n>req_tripstartdate}"/>
				<DatePicker
                    id="req_tripstartdate"
                    displayFormat="dd MMM yyyy"  
                    valueFormat="yyyy-MM-dd" 
                    placeholder="eg: 01 Jan 1990"
                    value="{reqDialog>/tripstartdate}"
					textAlign="Begin"
					required="{= ${reqDialog>/reqtype} === 'RT0001' || 
								${reqDialog>/reqtype} === 'RT0004' }"
					visible="false"/>

				<Label text="{i18n>req_tripenddate}" />
				<DatePicker
                    id="req_tripenddate"
                    displayFormat="dd MMM yyyy"  
                    valueFormat="yyyy-MM-dd" 
                    placeholder="eg: 01 Jan 1990"
                    value="{reqDialog>/tripenddate}"
					textAlign="Begin"
					required="{= ${reqDialog>/reqtype} === 'RT0001' || 
								${reqDialog>/reqtype} === 'RT0004' }"
					visible="false"/>

				<Label text="{i18n>req_eventstartdate}"/>
				<DatePicker
                    id="req_eventstartdate"
                    displayFormat="dd MMM yyyy"  
                    valueFormat="yyyy-MM-dd" 
                    placeholder="eg: 01 Jan 1990"
                    value="{reqDialog>/eventstartdate}"
					textAlign="Begin"
					required="{= ${reqDialog>/reqtype} === 'RT0001' || 
								${reqDialog>/reqtype} === 'RT0003' }"
					visible="false"/>

				<Label text="{i18n>req_eventenddate}" />
				<DatePicker
                    id="req_eventenddate"
                    displayFormat="dd MMM yyyy"  
                    valueFormat="yyyy-MM-dd" 
                    placeholder="eg: 01 Jan 1990"
                    value="{reqDialog>/eventenddate}"
					textAlign="Begin"
					required="{= ${reqDialog>/reqtype} === 'RT0001' || 
								${reqDialog>/reqtype} === 'RT0003' }"
					visible="false" />	

				<Label text="{i18n>req_grptype}" />
				<Select 
					id="req_grptype"
					selectedKey="{reqDialog>/grptype}" 
					required="true" 
					forceSelection="false"
					enabled="false"
					visible="false"
					items="{
						path: 'employee>/ZINDIV_GROUP',
						filters: [
							{ path: 'STATUS', operator: 'EQ', value1: 'ACTIVE' },
							{ path: 'IND_OR_GROUP_ID', operator: 'NE', value1: 'I_G' }
						],
						sorter: { path: 'IND_OR_GROUP_ID', descending: false }
					}">
					<items>
						<core:Item 
							key="{employee>IND_OR_GROUP_ID}" 
							text="{employee>IND_OR_GROUP_DESC}" />
					</items>
				</Select>

			    <Label text="{i18n>req_location}" />
			    <Input 
					id="req_location"
					textAlign="Begin"
					value="{reqDialog>/location}"
					required="{= ${reqDialog>/reqtype} === 'RT0001' || 
								${reqDialog>/reqtype} === 'RT0003' }"
					visible="false"/>

			    <Label text="{i18n>req_transport}" />
				<Input 
					id="req_transport"
					value="{reqDialog>/transport}"
					required="{= ${reqDialog>/reqtype} === 'RT0001' }"
					visible="false" />

			    <Label text="{i18n>req_acc}" />
				<mdc:Field
                        id="req_acc"
                        value="{reqDialog>/altcostcenter}"
						additionalValue="{reqDialog>/altcostcenter_desc}"
                        editMode="Editable"
                        display="ValueDescription"
                        visible="false"
                        valueHelp="valuehelp_requestinput_altcc"
                    />

			    <Label text="{i18n>req_attach1}" />
			    <unified:FileUploader
					id="req_attachment_1"
					change="onImportChange1"
					mimeType="application/pdf,image/png,image/jpeg"
					placeholder="{i18n>req_attachment_format}"
					value="{reqDialog>/doc1}"
					visible="false" />

			    <Label text="{i18n>req_attach2}" />
			    <unified:FileUploader
					id="req_attachment_2"
					change="onImportChange2"
					mimeType="application/pdf,image/png,image/jpeg"
					placeholder="{i18n>req_attachment_format}"
					value="{reqDialog>/doc2}"
					visible="false" />

			    <Label text="{i18n>req_comment}" />
			    <TextArea
					id="req_comment"
					textAlign="Begin"
					required="true"
					value="{reqDialog>/comment}"
					visible="false" />

				<Label text="{i18n>req_project}" />
				<Select 
					id="req_project"
					selectedKey="{reqDialog>/projectcode}" 
					required="true" 
					forceSelection="false"
					visible="false"
					items="{path: 'employee>/ZPROJECT_HDR',
							sorter: { path: 'PROJECT_CODE_IO', descending: false }}">
					<items>
						<core:Item key="{employee>PROJECT_CODE_IO}" 
								text="{employee>PROJECT_CODE_IO} :: {employee>PROJECT_DESC}" />
					</items>
				</Select>

				<!-- <Label text="{i18n>req_course}" />
				<Select 
					id="req_course"
					selectedKey="{reqDialog>/coursecode}" 
					required="true" 
					forceSelection="false"
					visible="false"
					items="{path: 'employee>/ZTRAIN_COURSE_PART',
							sorter: { path: 'COURSE_ID', descending: false }}">
					<items>
						<core:Item key="{employee>COURSE_ID}" 
								text="{employee>COURSE_ID} :: {employee>PROJECT_DESC}" />
					</items>
				</Select> -->
								
			</f:content>
			<f:dependents>
				<mdc:ValueHelp
					id="valuehelp_requestinput_altcc"
					delegate='\{
						"name": "claima/utils/ValueHelpDelegate_altcc",
						"payload": \{
							"searchKeys": ["COST_CENTER_ID", "COST_CENTER_DESC"],
							"columns": [
								"\{i18n>valuehelp_claiminput_altcc_col_id\}",
								"\{i18n>valuehelp_claiminput_altcc_col_name\}"
							]
						\}
					\}'
				>
					<mdc:typeahead>
						<mdcvh:Popover id="valuehelp_requestinput_altcc_pop">
							<mdcvhcnt:MTable id="valuehelp_requestinput_altcc_pop_MTable"
								keyPath="COST_CENTER_ID"
								descriptionPath="COST_CENTER_DESC"
								caseSensitive="false"
								useAsValueHelp="false">
								<!-- create table via delegate-->
							</mdcvhcnt:MTable>
						</mdcvh:Popover>
					</mdc:typeahead>
					<mdc:dialog>
						<mdcvh:Dialog
							id="valuehelp_requestinput_altcc_dialog"
							title="{i18n>valuehelp_claiminput_altcc}"
						>
							<mdcvhcnt:MTable
								id="valuehelp_requestinput_altcc_dialog_MTable"
								keyPath="COST_CENTER_ID"
								descriptionPath="COST_CENTER_DESC"
								caseSensitive="false">
								<!-- create table via delegate-->
							</mdcvhcnt:MTable>
						</mdcvh:Dialog>
					</mdc:dialog>
				</mdc:ValueHelp>
			</f:dependents>
        </f:SimpleForm>
		<HBox id="request_placeholder" alignItems="Center" justifyContent="End" class="sapUiSmallMarginEnd" columnGap="0.5rem">
            <Button id="request_create" press="onClickCreateRequest" 	text="{i18n>req_b_create}" type="Emphasized"/>
            <Button id="request_cancel" press="onClickCancel" 			text="{i18n>req_b_cancel}" />
		</HBox>
	</Dialog>
</core:FragmentDefinition>