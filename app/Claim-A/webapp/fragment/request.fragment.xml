<core:FragmentDefinition xmlns:unified="sap.ui.unified" xmlns:l="sap.ui.layout" xmlns:core="sap.ui.core" xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m" xmlns:f="sap.ui.layout.form">
	<Dialog title="{i18n>req_po_title}" contentWidth="50%" class="requestDialog">
		<f:SimpleForm 
            id="req_create_form"
			editable="true"
			layout="ResponsiveGridLayout"
			labelSpanXL="4"
			labelSpanL="3"
			labelSpanM="4"
			labelSpanS="12"
			adjustLabelSpan="false"
			emptySpanXL="0"
			emptySpanL="4"
			emptySpanM="0"
			emptySpanS="0"
			columnsXL="2"
			columnsL="1"
			columnsM="1" >
			<f:content>
				<Label text="{i18n>req_purpose}" />
				<Input value="{request>/req_header/purpose}" required="true"/>

				<Label text="{i18n>req_rtype}" />
				<Select selectedKey="{request>/req_header/reqtype}" 
						required="true" 
						forceSelection="false"
						items="{path: 'req_type_list>/types',
								sorter: { path: 'REQUEST_TYPE_ID', descending: false }}"
						change=".getFieldVisibility_ReqType">
					<items>
						<core:Item key="{req_type_list>REQUEST_TYPE_ID}" 
								text="{req_type_list>REQUEST_TYPE_DESC}" />
					</items>
				</Select>

				<Label text="{i18n>req_claimtype}" />
				<Select selectedKey="{request>/req_header/claimtype}" 
						required="true" 
						forceSelection="false"
						items="{path: 'claim_type_list>/types',
								sorter: { path: 'CLAIM_TYPE_ID', descending: false }}">
					<items>
						<core:Item key="{claim_type_list>CLAIM_TYPE_ID}" 
								text="{claim_type_list>CLAIM_TYPE_DESC}" />
					</items>
				</Select>

			    <Label text="{i18n>req_tripstartdate}"/>
				<DatePicker
                    id="req_tripstartdate"
                    displayFormat="dd MMM yyyy"  
                    valueFormat="yyyy-MM-dd" 
                    placeholder="eg: 01 Jan 1990"
                    value="{request>/req_header/tripstartdate}"
					textAlign="Begin"
					required="{= ${request>/req_header/reqtype} === 'RT0001' || 
								${request>/req_header/reqtype} === 'RT0004' }"
					visible="false"/>

				<Label text="{i18n>req_tripenddate}" />
				<DatePicker
                    id="req_tripenddate"
                    displayFormat="dd MMM yyyy"  
                    valueFormat="yyyy-MM-dd" 
                    placeholder="eg: 01 Jan 1990"
                    value="{request>/req_header/tripenddate}"
					textAlign="Begin"
					required="{= ${request>/req_header/reqtype} === 'RT0001' || 
								${request>/req_header/reqtype} === 'RT0004' }"
					visible="false"/>

				<Label text="{i18n>req_eventstartdate}"/>
				<DatePicker
                    id="req_eventstartdate"
                    displayFormat="dd MMM yyyy"  
                    valueFormat="yyyy-MM-dd" 
                    placeholder="eg: 01 Jan 1990"
                    value="{request>/req_header/eventstartdate}"
					textAlign="Begin"
					required="{= ${request>/req_header/reqtype} === 'RT0001' || 
								${request>/req_header/reqtype} === 'RT0003' }"
					visible="false"/>

				<Label text="{i18n>req_eventenddate}" />
				<DatePicker
                    id="req_eventenddate"
                    displayFormat="dd MMM yyyy"  
                    valueFormat="yyyy-MM-dd" 
                    placeholder="eg: 01 Jan 1990"
                    value="{request>/req_header/eventenddate}"
					textAlign="Begin"
					required="{= ${request>/req_header/reqtype} === 'RT0001' || 
								${request>/req_header/reqtype} === 'RT0003' }"
					visible="false" />	

				<Label text="{i18n>req_grptype}" />
				<Select 
					id="req_grptype"
					selectedKey="{request>/req_header/grptype}" 
						required="true" 
						forceSelection="false"
						enabled="{= ${request>/req_header/reqtype} !== 'RT0004'}"
						visible="false"
						items="{path: 'indiv_list>/types',
								sorter: { path: 'IND_OR_GROUP_ID', descending: false }}">
					<items>
						<core:Item key="{indiv_list>IND_OR_GROUP_ID}" 
								text="{indiv_list>IND_OR_GROUP_DESC}" />
					</items>
				</Select>

			    <Label text="{i18n>req_location}" />
			    <Input 
					id="req_location"
					textAlign="Begin"
					value="{request>/req_header/location}"
					required="{= ${request>/req_header/reqtype} === 'RT0001' || 
								${request>/req_header/reqtype} === 'RT0003' }"
					visible="false"/>

			    <Label text="{i18n>req_transport}" />
				<Input 
					id="req_transport"
					value="{request>/req_header/transport}"
					required="{= ${request>/req_header/reqtype} === 'RT0001' }"
					visible="false" />

			    <Label text="{i18n>req_acc}" />
			    <Select 
					id="req_acc"
					selectedKey="{request>/req_header/altcostcenter}" 
					required="true" 
					forceSelection="false"
					visible="false"
					items="{path: 'employee>/ZCOST_CENTER',
							sorter: { path: 'COST_CENTER_ID', descending: false }}">
					<items>
						<core:Item key="{employee>COST_CENTER_ID}" 
								text="{employee>COST_CENTER_DESC}" />
					</items>
				</Select>

			    <Label text="{i18n>req_attach1}" />
			    <unified:FileUploader
					id="req_attachment_1"
					change=".onImportChange"
					value="{request>/req_header/doc1}"
					required="true"
					visible="false" />

			    <Label text="{i18n>req_attach2}" />
			    <unified:FileUploader
					id="req_attachment_2"
					change=".onImportChange"
					value="{request>/req_header/doc2}"
					visible="false" />

			    <Label text="{i18n>req_comment}" />
			    <TextArea
					id="req_comment"
					textAlign="Begin"
					required="true"
					value="{request>/req_header/comment}"
					visible="false" />

				<Label text="{i18n>req_project}" />
				<Select 
					id="req_project"
					selectedKey="{request>/req_header/projectcode}" 
					required="true" 
					forceSelection="false"
					visible="false"
					items="{path: 'employee>/ZPROJECT_HDR',
							sorter: { path: 'PROJECT_CODE_IO', descending: false }}">
					<items>
						<core:Item key="{employee>PROJECT_CODE_IO}" 
								text="{employee>PROJECT_CODE_IO} :: {employee>PROJECT_DESC}" />
					</items>
				</Select>
								
			</f:content>
        </f:SimpleForm>
		<HBox id="request_placeholder" alignItems="Center" justifyContent="End" class="sapUiSmallMarginEnd" columnGap="0.5rem">
            <Button id="request_create" press="onClickCreateRequest" 	text="{i18n>req_b_create}" type="Emphasized"/>
            <Button id="request_cancel" press="onClickCancel" 			text="{i18n>req_b_cancel}" />
		</HBox>
	</Dialog>
</core:FragmentDefinition>