
<core:FragmentDefinition
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:card="sap.f.cards"
    xmlns:u="sap.ui.unified"
>
    <VBox class="sapUiSmallMargin">
        <VBox
            class="sapUiMediumMargin"
            width="100%"
        >
         <HBox class="sapUiTinyMarginBottom" alignItems="Start">
            <Label text="{i18n>claimtypeid}  :  " />
            <Text text="{CLAIM_TYPE_ID}" />
        </HBox>

        <HBox class="sapUiTinyMarginBottom" alignItems="Start">
            <Label text="{i18n>claimtypedesc} :  " />
            <Text text="{CLAIM_TYPE_DESC}" wrapping="true" />
        </HBox>

        <HBox class="sapUiTinyMarginBottom" alignItems="Start">
            <Label text="{i18n>label_claimdetails_input_startdate} :  " />
            <Text text="{path: 'START_DATE', type: 'sap.ui.model.odata.type.Date', formatOptions: { pattern: 'dd MMM yyyy' }}" />
        </HBox>

        <HBox class="sapUiTinyMarginBottom" alignItems="Start">
            <Label text="{i18n>label_claimdetails_input_enddate}  :  " />
            <Text text="{path: 'END_DATE', type: 'sap.ui.model.odata.type.Date', formatOptions: { pattern: 'dd MMM yyyy' }}" />
        </HBox>

        <HBox class="sapUiTinyMarginBottom" alignItems="Start">
            <Label text="{i18n>appr_status}  :" />
            <Text text="{STATUS}" />
        </HBox>
        </VBox>
        <VBox width="100%">
            <Toolbar width="90%">
                <Title text="{i18n>conf_zclaimtpeitem}" />
                <ToolbarSpacer />
                <Button
                    id="EditItem"
                    text="{i18n>req_b_edit}"
                    press="onEdit"
                    enabled="{view>/hasSelection}"
                    visible="{= ${/FeatureControl/operationEnabled} }"
                />
                <Button
                    id="CopyItem"
                    text="{i18n>copy}"
                    press="onCopy"
                    enabled="{view>/hasSelection}"
                    visible="{= ${/FeatureControl/operationEnabled} }"
                />
                <Button
                    id="CreateItem"
                    text="{i18n>create}"
                    press="onCreate"
                    enabled="true"
                    visible="{= ${/FeatureControl/operationEnabled} }"
                />
                <Button
                    id="DeleteItem"
                    text="{i18n>req_b_delete}"
                    press="onDelete"
                    enabled="{view>/hasSelection}"
                    visible="{= ${/FeatureControl/operationEnabled} }"
                />
                <Button
                    icon="sap-icon://action-settings"
                    press="onOpenViewItemSettings"
                    type="Transparent"
                    tooltip="View Settings"
                />
                <Button icon="sap-icon://excel-attachment" 
                press="onExportToExcel" 
                type="Transparent" 
                tooltip="Export to Excel" />
            </Toolbar>

            <Table
                id="claimitemTable"
                width="90%"
                items="{path: 'Items',sorter : { path : 'modifiedAt', descending: false }}"
                mode="MultiSelect"
                selectionChange="onSelectionChange"
                includeItemInSelection="true"
            >
                <columns>
                    <Column>
                        <Text text="{i18n>claimtypeitemid}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>claimdesc}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>categoryid}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>req_cc}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>materialcode}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>risk}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>submitted_type}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>req_i_start_date}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>req_i_end_date}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>appr_status}" />
                    </Column>
                </columns>

                <items>
                    <ColumnListItem>
                        <cells>
                            <Text text="{CLAIM_TYPE_ITEM_ID}" />
                            <Text text="{CLAIM_TYPE_ITEM_DESC}" />
                            <Text text="{CATEGORY_ID}" />
                            <Text text="{COST_CENTER}" />
                            <Text text="{MATERIAL_CODE}" />
                            <Text text="{RISK}" />
                            <Text text="{SUBMISSION_TYPE}" />
                            <Text text="{START_DATE}" />                            
                            <Text text="{END_DATE}" />
                            <Text text="{STATUS}" />                            
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
