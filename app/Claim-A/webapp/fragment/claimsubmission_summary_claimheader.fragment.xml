<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:mdc="sap.ui.mdc"
    xmlns:mdcvh="sap.ui.mdc.valuehelp"
    xmlns:mdcvhcnt="sap.ui.mdc.valuehelp.content"
    xmlns:mdc="sap.ui.mdc"
    xmlns:mdcvh="sap.ui.mdc.valuehelp"
    xmlns:mdcvhcnt="sap.ui.mdc.valuehelp.content"
	core:require="{FloatType: 'sap/ui/model/type/Float'}"
>
    <VBox 
        backgroundDesign="Solid"
        class="roundedBox sapUiSmallMargin sapUiTinyMarginBottom"
        rowGap="1rem">
        <OverflowToolbar height="3rem">
            <!-- Claim Header -->
            <Title
                text="{i18n>title_claimsummary_claimheader}"
            />

            <!-- space -->
            <ToolbarSpacer />

            <!-- Attachment -->
            <Button
                id="button_claimsummary_viewattachment"
                icon="sap-icon://attachment"
                text="{i18n>button_claimsummary_viewattachment}"
                press="onView_Claim_Attachment('parent')"
                enabled="{= ${claimsubmission_input>/claim_header/attachment_email_approver} !== null}"
            />

            <!-- Download details -->
            <Button
                type="Default"
                icon="sap-icon://excel-attachment"
                text="{i18n>downloaddetails}"
                id="btnExcelDownload2"
                press=".onDownloadExcelReport"
            />
            
            <!-- Save header -->
            <Button
                type="Default"
                icon="sap-icon://save"
                text="{i18n>button_claimdetails_input_save}"
                id="btnExcelDownload3"
                press=".onSaveHeader"
                visible="{claimSubmissionHeaderEditableModel>/saveHeader}"
            />

        </OverflowToolbar>
        <f:SimpleForm
            editable="false"
            layout="ColumnLayout"
            labelSpanXL="5"
            labelSpanL="5"
            labelSpanM="5"
            labelSpanS="10"
            adjustLabelSpan="true"
            emptySpanXL="1"
            emptySpanL="1"
            emptySpanM="1"
            emptySpanS="0"
            columnsM="2"
            columnsL="2"
            columnsXL="2"
            singleContainerFullSize="false"
        >
            <f:content>
                <!-- Report Purpose -->
                <Label text="{i18n>label_claimsummary_claimheader_purpose}" />
                <Text
                    id="text_claimsummary_claimheader_purpose"
                    text="{claimsubmission_input>/claim_header/purpose}"
                />

                <!-- Claim ID -->
                <Label text="{i18n>label_claimsummary_claimheader_claimid}" />
                <Text
                    id="text_claimsummary_claimheader_claimid"
                    text="{claimsubmission_input>/claim_header/claim_id}"
                />

                <!-- Course Code -->
                <Label text="{i18n>label_claimsummary_claimheader_course_code}" />
                <Text
                    id="text_claimsummary_claimheader_course_code"
                    text="{claimsubmission_input>/claim_header/course_code} - {claimsubmission_input>/claim_header/descr/course_code}"
                    visible="{= !!${claimsubmission_input>/claim_header/course_code} }"
                />

                <!-- Session Number -->
                <Label text="{i18n>label_claimsummary_claimheader_session_number}" />
                <Text
                    id="text_claimsummary_claimheader_session_number"
                    text="{claimsubmission_input>/claim_header/session_number}"
                    visible="{= !!${claimsubmission_input>/claim_header/session_number} }"
                />

                <!-- Trip Start Date -->
                <Label
                    text="{i18n>label_claimsummary_claimheader_tripstartdate}"
                    required="true"
                    tooltip="{i18n>valuehelp_claiminput_tripdate}"
                />
                
                <DatePicker
                
                <DatePicker
                    id="text_claimsummary_claimheader_tripstartdate"
                    editable="{claimSubmissionHeaderEditableModel>/startTrip}"
                    value="{
						path: 'claimsubmission_input>/claim_header/trip_start_date',
						type: 'sap.ui.model.odata.type.Date',
						formatOptions: { pattern: 'dd-MMM-yyyy' }
					}"
                />

                <!-- Trip End Date -->
                <Label
                    text="{i18n>label_claimsummary_claimheader_tripenddate}"
                    required="true"
                    tooltip="{i18n>valuehelp_claiminput_tripdate}"
                />
                <DatePicker
                <DatePicker
                    id="text_claimsummary_claimheader_tripenddate"
                    editable="{claimSubmissionHeaderEditableModel>/endTrip}"
                    value="{
						path: 'claimsubmission_input>/claim_header/trip_end_date',
						type: 'sap.ui.model.odata.type.Date',
						formatOptions: { pattern: 'dd-MMM-yyyy' }
					}"
                />

                <!-- Event Start Date -->
                <Label
                    text="{i18n>label_claimsummary_claimheader_eventstartdate}"
                    tooltip="{i18n>valuehelp_claiminput_eventdate}"
                />
                <DatePicker
                <DatePicker
                    id="text_claimsummary_claimheader_eventstartdate"
                    editable="{claimSubmissionHeaderEditableModel>/startEvent}"
                    value="{
						path: 'claimsubmission_input>/claim_header/event_start_date',
						type: 'sap.ui.model.odata.type.Date',
						formatOptions: { pattern: 'dd-MMM-yyyy' }
					}"
                />

                <!-- Event End Date -->
                <Label
                    text="{i18n>label_claimsummary_claimheader_eventenddate}"
                    tooltip="{i18n>valuehelp_claiminput_eventdate}"
                />
                <DatePicker
                <DatePicker
                    id="text_claimsummary_claimheader_eventenddate"
                    editable="{claimSubmissionHeaderEditableModel>/endEvent}"
                    value="{
						path: 'claimsubmission_input>/claim_header/event_end_date',
						type: 'sap.ui.model.odata.type.Date',
						formatOptions: { pattern: 'dd-MMM-yyyy' }
					}"
                />

                <!-- Move-In Date -->
                <Label
                    text="{i18n>label_claimsummary_claimheader_move_in_date}"
                />
                <Text
                    id="text_claimsummary_claimheader_move_in_date"
                    text="{
						path: 'claimsubmission_input>/claim_header/move_in_date',
						type: 'sap.ui.model.odata.type.Date',
						formatOptions: { pattern: 'dd-MMM-yyyy' }
					}"
                    visible="{= ${claimsubmission_input>/claim_header/claim_type_id} === ${constant>/ClaimType/ELAUN_PINDAH} }"
                />

                <!-- Pre-Approval Request -->
                <Label
                    text="{i18n>label_claimsummary_claimheader_preapprovalreq}"
                />
                <Text
                    id="text_claimsummary_claimheader_preapprovalreq"
                    text="{claimsubmission_input>/claim_header/request_id} {claimsubmission_input>/claim_header/descr/request_id}"
                />

                <!-- Comment -->
                <Label text="{i18n>label_claimsummary_claimheader_comment}" />
                <Input
                <Input
                    id="text_claimsummary_claimheader_comment"
                    editable="{claimSubmissionHeaderEditableModel>/comment}"
                    value="{claimsubmission_input>/claim_header/comment}"
                />

                <!-- Location -->
                <Label text="{i18n>label_claimsummary_claimheader_location}" />
                <Input
                <Input
                    id="text_claimsummary_claimheader_location"
                    editable="{claimSubmissionHeaderEditableModel>/location}"
                    value="{claimsubmission_input>/claim_header/location}"
                    placeholder="{i18n>placeholder_claiminput_location}"
                />

                <!-- Cost Center -->
                <Label text="{i18n>label_claimsummary_claimheader_cc}" />
                <Text
                    id="text_claimsummary_claimheader_cc"
                    text="{claimsubmission_input>/claim_header/cost_center} {claimsubmission_input>/claim_header/descr/cost_center}"
                />

                <!-- Alternate Cost Center -->
                <Label text="{i18n>label_claimsummary_claimheader_altcc}" />
                <mdc:Field
                        id="text_claimsummary_claimheader_altcc"
                        value="{claimsubmission_input>/claim_header/alternate_cost_center}"
                        additionalValue="{claimsubmission_input>/claim_header/descr/alternate_cost_center}"
                        editMode="{= ${claimSubmissionHeaderEditableModel>/altCostCenter} ? 'Editable' : 'Display' }"
                        display="ValueDescription"
                        visible="{= ${claimsubmission_input>/claimtype/cost_center} === null &amp;&amp;
                            ${claimsubmission_input>/claimtype/requestform/alternate_cost_center} === null
                        }"
                        valueHelp="valuehelp_claiminput_altcc"
                />

                <!-- Claim Status -->
                <Label text="{i18n>label_claimsummary_claimheader_status}" />
                <Text
                    id="text_claimsummary_claimheader_status"
                    text="{claimsubmission_input>/claim_header/descr/status_id}"
                />

                <!-- Total Claim (MYR) -->
                <Label text="{i18n>label_claimsummary_claimheader_amttotal}" />
                <Text
                    id="text_claimsummary_claimheader_amttotal"
                    text="{
                        path: 'claimsubmission_input>/claim_header/total_claim_amount',
                        type: 'FloatType',
                        formatOptions: {
                            minFractionDigits: 2,
                            maxFractionDigits: 2,
                            preserveDecimals: false
                        }
                    }"
                    textAlign="End"
                />

                <!-- Pre-Approved Amount (MYR) -->
                <Label
                    text="{i18n>label_claimsummary_claimheader_amtapproved}"
                />
                <Text
                    id="text_claimsummary_claimheader_amtapproved"
                    text="{
                        path: 'claimsubmission_input>/claim_header/preapproved_amount',
                        type: 'FloatType',
                        formatOptions: {
                            minFractionDigits: 2,
                            maxFractionDigits: 2,
                            preserveDecimals: false
                        }
                    }"
                    textAlign="End"
                />

                <!-- Cash Advance (MYR) -->
                <Label
                    text="{i18n>label_claimsummary_claimheader_amtcashadvance}"
                />
                <Text
                    id="text_claimsummary_claimheader_amtcashadvance"
                    text="{
                        path: 'claimsubmission_input>/claim_header/cash_advance_amount',
                        type: 'FloatType',
                        formatOptions: {
                            minFractionDigits: 2,
                            maxFractionDigits: 2,
                            preserveDecimals: false
                        }
                    }"
                    textAlign="End"
                />

                <!-- Final Amount to Receive (MYR) -->
                <Label
                    text="{i18n>label_claimsummary_claimheader_amtreceivefinal}"
                />
                <Text
                    id="text_claimsummary_claimheader_amtreceivefinal"
                    text="{
                        path: 'claimsubmission_input>/claim_header/final_amount_to_receive',
                        type: 'FloatType',
                        formatOptions: {
                            minFractionDigits: 2,
                            maxFractionDigits: 2,
                            preserveDecimals: false
                        }
                    }"
                    textAlign="End"
                />
            </f:content>
            <f:dependents>
                    <mdc:ValueHelp
                        id="valuehelp_claiminput_altcc"
                        delegate='\{
                            "name": "claima/utils/ValueHelpDelegate_altcc",
                            "payload": \{
                                "searchKeys": ["COST_CENTER_ID", "COST_CENTER_DESC"],
                                "columns": [
                                    "\{i18n>valuehelp_claiminput_altcc_col_id\}",
                                    "\{i18n>valuehelp_claiminput_altcc_col_name\}"
                                ]
                            \}
                        \}'
                    >
                        <mdc:typeahead>
                            <mdcvh:Popover id="valuehelp_claiminput_altcc_pop">
                                <mdcvhcnt:MTable id="valuehelp_claiminput_altcc_pop_MTable"
                                    keyPath="COST_CENTER_ID"
                                    descriptionPath="COST_CENTER_DESC"
                                    caseSensitive="false"
                                    useAsValueHelp="false">
                                    <!-- create table via delegate-->
                                </mdcvhcnt:MTable>
                            </mdcvh:Popover>
                        </mdc:typeahead>
                        <mdc:dialog>
                            <mdcvh:Dialog
                                id="valuehelp_claiminput_altcc_dialog"
                                title="{i18n>valuehelp_claiminput_altcc}"
                            >
                                <mdcvhcnt:MTable
                                    id="valuehelp_claiminput_altcc_dialog_MTable"
                                    keyPath="COST_CENTER_ID"
                                    descriptionPath="COST_CENTER_DESC"
                                    caseSensitive="false">
                                    <!-- create table via delegate-->
                                </mdcvhcnt:MTable>
                            </mdcvh:Dialog>
                        </mdc:dialog>
                    </mdc:ValueHelp>
                </f:dependents>
        </f:SimpleForm>
    </VBox>
</core:FragmentDefinition>
