<core:FragmentDefinition
    xmlns:unified="sap.ui.unified" 
    xmlns:columnmenu="sap.m.table.columnmenu" 
    xmlns:table="sap.ui.table" 
    xmlns:m="sap.m"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:tnt="sap.tnt"
    xmlns:cards="sap.f.cards"
    xmlns:f="sap.f"
    xmlns:l="sap.ui.layout"
    xmlns:cssgrid="sap.ui.layout.cssgrid"
    xmlns:w="sap.ui.integration.widgets"
    xmlns:card="sap.f.cards"
    xmlns:core="sap.ui.core"
    xmlns:Icon="sap.ui.core.Icon"
    xmlns:ShellBar="sap.f.ShellBar"
    xmlns:layout="sap.ui.layout">
    <VBox
        id="request_item_list_fragment" 
        backgroundDesign="Solid"
        class="roundedBox sapUiSmallMargin sapUiTinyMarginTop sapUiTinyMarginBottom"
        rowGap="1rem">
        <VBox width="100%" rowGap="1rem">
            <OverflowToolbar   
                height="3rem"
                style="Clear">
                <m:Title text="{i18n>req_form_detail_title} ({= ${request>/list_count} })"/>
                <m:ToolbarSpacer />
                <m:Button text="{i18n>req_b_create_item}"   type="Emphasized"   press=".onAddItem"          enabled="{= ${request>/view} === 'list' }" />
                <m:Button text="{i18n>req_b_delete}"        type="Default"      press=".onRowDeleteReqItem" enabled="{= ${request>/view} === 'list' }" />
            </OverflowToolbar>
            <VBox rowGap="1rem">
                <table:Table 
                    id="req_item_table"
                    rows="{request>/req_item_rows}"
                    columnHeaderHeight="3rem"
                    selectionMode="{= ${request>/view} !== 'list' ? 'None' : 'MultiToggle' }"
                    ariaLabelledBy="title"
                    width="auto"
                    rowActionCount="2">
                    <table:Column  width="25rem">
                        <m:Label text="{i18n>req_i_claim_type_item}"></m:Label>
                        <table:template>
                            <m:Text text="{request>CLAIM_TYPE_ITEM_DESC}" wrapping="false" />
                        </table:template>
                    </table:Column>
                    <table:Column  width="15rem">
                        <m:Label text="{i18n>req_i_est_amt}"></m:Label>
                        <table:template>
                            <unified:Currency value="{request>EST_AMOUNT}" 
                                              currency="MYR" 
                                              useSymbol="true"/>
                        </table:template>
                    </table:Column>
                    <table:Column  width="15rem">
                        <m:Label text="{i18n>req_i_estparticipant}"></m:Label>
                        <table:template>
                            <m:Text text="{request>EST_NO_PARTICIPANT}" />
                        </table:template>
                    </table:Column>
                    <table:rowActionTemplate>
                        <table:RowAction> 
                            <table:items>
                                <table:RowActionItem type="Delete"      press=".onRowDeleteReqItem" visible="{= ${request>/view} === 'list' }" />
                                <table:RowActionItem type="Custom"      press=".onOpenItemEdit"     visible="{= ${request>/view} === 'list' }"  icon="sap-icon://edit"  text="Edit"/>
                                <table:RowActionItem type="Navigation"  press=".onOpenItemView"     visible="{= ${request>/view} === 'view' || ${request>/view} === 'approver' }" />
                            </table:items>
                        </table:RowAction>
                    </table:rowActionTemplate>
                </table:Table>
            </VBox>
        </VBox>
        <!-- for ccc -->
        <VBox width="100%" rowGap="1rem" visible="{= ${request>/req_header/reqtypeid} ===  ${constant>/RequestType/CORP_CC} }">
            <OverflowToolbar   
                height="3rem"
                style="Clear">
                <m:Title text="{i18n>req_form_detail_ccc_title}"/>
                <m:ToolbarSpacer />
            </OverflowToolbar>
            <VBox rowGap="1rem">
                <table:Table 
                    id="req_ccc_table"
                    rows="{request>/corpo_cards}"
                    columnHeaderHeight="3rem"
                    selectionMode="None"
                    ariaLabelledBy="title"
                    fixedColumnCount="2"
                    cellClick="onCellClick">
                    <table:Column width="10rem">
                        <Label text="{i18n>req_card_number}"></Label>
                        <table:template>
                            <Text text="{request>CARD_NO}" />
                        </table:template>
                    </table:Column>
                    <table:Column width="15rem">
                        <Label text="{i18n>req_cardholder_name}"></Label>
                        <table:template>
                            <Text text="{request>CARDHOLDER_NAME}" />
                        </table:template>
                    </table:Column>
                    <table:Column width="15rem" >
                        <Label text="{i18n>req_current_balance}"></Label>
                        <table:template>
                            <Text text="{request>current_balance}" />
                        </table:template>
                    </table:Column>
                    <table:Column width="15rem" >
                        <Label text="{i18n>req_service_tax}"></Label>
                        <table:template>
                            <Text text="{request>service_tax}" />
                        </table:template>
                    </table:Column>
                    <table:Column width="15rem" id="merchantRefundColumn" >
                        <Label text="{i18n>req_merchant_refund}"></Label>
                        <table:template>
                            <Text text="{request>merchant_refunds_total}" />
                        </table:template>
                    </table:Column>
                    <table:Column width="15rem">
                        <Label text="{i18n>req_cashback}"></Label>
                        <table:template>
                            <Text text="{request>cashback}" />
                        </table:template>
                    </table:Column>
                    <table:Column width="15rem">
                        <Label text="{i18n>req_adv_amt}"></Label>
                        <table:template>
                            <Text text="{request>advance_amount}" />
                        </table:template>
                    </table:Column>
                </table:Table>
            </VBox>
        </VBox>
    </VBox>
</core:FragmentDefinition>