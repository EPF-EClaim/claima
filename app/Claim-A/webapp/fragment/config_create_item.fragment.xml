<core:FragmentDefinition
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:card="sap.f.cards"
    xmlns:u="sap.ui.unified"
>

    <Dialog
        id="copyRecordDialog"
        title="Copy Record"
        contentWidth="15%"
        horizontalScrolling="false"
        afterClose=".onCopyRecordDialogAfterClose">

        <!-- Dynamic VBox passed via controller -->
        <VBox id="copyDialogVBox" />

        <beginButton>
            <Button
                text="Copy"
                press=".onCopyRecordPress" />
        </beginButton>

        <endButton>
            <Button
                text="Cancel"
                press=".onCopyRecordCancel" />
        </endButton>
    </Dialog>

</core:FragmentDefinition>