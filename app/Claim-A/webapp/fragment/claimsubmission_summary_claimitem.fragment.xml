<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core"
    core:require="{FloatType: 'sap/ui/model/type/Float'}"
>
    <VBox class="sapUiSmallMargin">
        <!-- Claim Item Toolbar -->
        <Toolbar>
            <!-- Claim Item -->
            <Title
                text="{
					parts:[
						{path:'i18n>title_claimsummary_claimitem'},
						{path:'claimsubmission_input>/claim_items_count'}
					], 
					formatter:'jQuery.sap.formatMessage'}"
                level="H2"
            />

            <!-- space -->
            <ToolbarSpacer />

			<!-- Create Claim -->
			<Button
				id="button_claimsummary_createclaim"
				text="{i18n>menuitem_claimsummary_createclaim}"
				press="onCreateClaim_ClaimSummary()"
				type="Emphasized"
			/>

            <!-- Edit -->
            <Button
                id="button_claimsummary_edit"
                text="{i18n>button_claimsummary_edit}"
                press="onAction_ClaimSummary('Edit')"
                enabled="false"
            />

			<!-- Duplicate -->
			<Button
				id="button_claimsummary_duplicate"
				text="{i18n>button_claimsummary_duplicate}"
				press="onAction_ClaimSummary('Duplicate')"
				enabled="false"
			/>

            <!-- Delete -->
            <Button
                id="button_claimsummary_delete"
                text="{i18n>button_claimsummary_delete}"
                press="onAction_ClaimSummary('Delete')"
                enabled="false"
            />
        </Toolbar>

        <!-- Table for Claim Items -->
        <Table
            id="table_claimsummary_claimitem"
            inset="false"
            mode="MultiSelect"
            itemPress="onItemPress_ClaimSubmission"
            items="{
				path: 'claimsubmission_input>/claim_items',
				sorter: {
					path: 'claim_sub_id'
				}
			}"
            growing="true"
            growingScrollToLoad="false"
            sticky="ColumnHeaders"
        >
            <columns>
                <!-- Item -->
                <Column>
                    <Text text="Item" />
                </Column>

				<!-- Claim Type -->
				<Column>
					<Text text="{i18n>columntext_claimsummary_claimtype}" />
				</Column>

                <!-- Claim Item -->
                <Column>
                    <Text text="{i18n>columntext_claimsummary_claimitem}" />
                </Column>

				<!-- Amount -->
				<Column hAlign="End" >
					<Text text="{i18n>columntext_claimsummary_amt}" />
				</Column>

                <!-- Remarks -->
                <Column>
                    <Text text="{i18n>columntext_claimsummary_remarks}" />
                </Column>

                <!-- Attachment 1 -->
                <Column>
                    <Text text="{i18n>columntext_claimsummary_attachment1}" />
                </Column>

                <!-- Attachment 2 -->
                <Column>
                    <Text text="{i18n>columntext_claimsummary_attachment2}" />
                </Column>
            </columns>

            <items>
                <ColumnListItem
                    type="Active"
                    vAlign="Middle"
                >
                    <cells>
                        <!-- Item ID -->
                        <ObjectIdentifier
                            text="{claimsubmission_input>claim_sub_id}"
                        />

						<!-- Claim Type -->
						<Text text="{claimsubmission_input>descr/claim_type_id}" />

                        <!-- Claim Item -->
                        <Text
                            text="{claimsubmission_input>descr/claim_type_item_id}"
                        />

                        <!-- Amount -->
                        <Text
                            text="{
								path: 'claimsubmission_input>amount',
								type: 'FloatType',
								formatOptions: {
									minFractionDigits: 2,
									maxFractionDigits: 2,
									preserveDecimals: false
								}
							}"
                        />

                        <!-- Remarks -->
                        <Text text="{claimsubmission_input>remark}" />

                        <!-- Attachment 1 -->
                        <Button
                            id="button_claimsummary_attachment1"
                            icon="sap-icon://attachment"
                            text="{i18n>button_claimdetails_input_viewattachment}"
                            press="onView_Claim_Attachment('child','1', ${claimsubmission_input>claim_sub_id})"
                            enabled="{= ${claimsubmission_input>attachment_file_1} !== null }"
                        />

                        <!-- Attachment 2 -->
                        <Button
                            id="button_claimsummary_attachment2"
                            icon="sap-icon://attachment"
                            text="{i18n>button_claimdetails_input_viewattachment}"
                            press="onView_Claim_Attachment('child','2', ${claimsubmission_input>claim_sub_id})"
                            enabled="{= ${claimsubmission_input>attachment_file_2} !== null }"
                        />
                    </cells>
                </ColumnListItem>
            </items>
        </Table>
    </VBox>
</core:FragmentDefinition>
