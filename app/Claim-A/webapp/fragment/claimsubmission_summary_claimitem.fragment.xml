<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core"
    core:require="{FloatType: 'sap/ui/model/type/Float',
				   DateType: 'sap/ui/model/odata/type/Date'}"
>
    <VBox
        backgroundDesign="Solid"
        class="roundedBox sapUiSmallMargin"
        rowGap="1rem">
        <!-- Claim Item Toolbar -->
        <OverflowToolbar
            height="3rem"
            style="Clear">
            <!-- Claim Item -->
            <Title  
                text="{
					parts:[
						{path:'i18n>title_claimsummary_claimitem'},
						{path:'claim>/claim_items_count'}
					], 
					formatter:'jQuery.sap.formatMessage'}"
            />

            <!-- space -->
            <ToolbarSpacer />

			<!-- Create Claim -->
			<Button
				id="button_claimsummary_createclaim"
				text="{i18n>menuitem_claimsummary_createclaim}"
				press="onCreateClaim_ClaimSummary()"
				type="Emphasized"
			/>

            <!-- Edit -->
            <Button
                id="button_claimsummary_edit"
                text="{i18n>button_claimsummary_edit}"
                press="onAction_ClaimSummary('Edit')"
                enabled="false"
            />

			<!-- Duplicate -->
			<Button
				id="button_claimsummary_duplicate"
				text="{i18n>button_claimsummary_duplicate}"
				press="onAction_ClaimSummary('Duplicate')"
				enabled="false"
			/>

            <!-- Delete -->
            <Button
                id="button_claimsummary_delete"
                text="{i18n>button_claimsummary_delete}"
                press="onAction_ClaimSummary('Delete')"
                enabled="false"
            />
        </OverflowToolbar>

        <!-- Table for Claim Items -->
        <Table
            id="table_claimsummary_claimitem"
            inset="false"
            mode="MultiSelect"
            selectionChange="onSelectionChange_ClaimSummary"
            itemPress="onItemPress_ClaimSubmission"
            items="{
				path: 'claim>/claim_items',
				sorter: {
					path: 'claim_sub_id'
				}
			}"
            growing="true"
            growingScrollToLoad="false"
            sticky="ColumnHeaders"
        >
            <columns>
                <!-- Item -->
                <Column>
                    <Text text="Item" />
                </Column>

				<!-- Claim Type -->
				<Column>
					<Text text="{i18n>columntext_claimsummary_claimtype}" />
				</Column>

                <!-- Claim Item -->
                <Column>
                    <Text text="{i18n>columntext_claimsummary_claimitem}" />
                </Column>

				<!-- Amount -->
				<Column hAlign="End" >
					<Text text="{i18n>columntext_claimsummary_amt}" />
				</Column>

				<!-- Receipt Number -->
				<Column>
					<Text text="{i18n>columntext_claimsummary_receipt_number}" />
				</Column>

				<!-- Receipt Date -->
				<Column>
					<Text text="{i18n>columntext_claimsummary_receipt_date}" />
				</Column>

                <!-- Remarks -->
                <Column>
                    <Text text="{i18n>columntext_claimsummary_remarks}" />
                </Column>

                <!-- Attachment 1 -->
                <Column>
                    <Text text="{i18n>columntext_claimsummary_attachment1}" />
                </Column>

                <!-- Attachment 2 -->
                <Column>
                    <Text text="{i18n>columntext_claimsummary_attachment2}" />
                </Column>

            </columns>

            <items>
                <ColumnListItem
                    type="Active"
                    vAlign="Middle"
                >
                    <cells>
                        <!-- Item ID -->
                        <ObjectIdentifier
                            text="{claim>CLAIM_SUB_ID}"
                        />

						<!-- Claim Type -->
						<Text text="{claim>CLAIM_TYPE_DESC}" />

                        <!-- Claim Item -->
                        <Text
                            text="{claim>CLAIM_TYPE_ITEM_DESC}"
                        />

                        <!-- Amount -->
                        <Text
                            text="{
								path: 'claim>AMOUNT',
								type: 'FloatType',
								formatOptions: {
									minFractionDigits: 2,
									maxFractionDigits: 2,
									preserveDecimals: false
								}
							}"
                        />

                        <!-- Receipt Number -->
                        <Text
                            text="{claim>RECEIPT_NUMBER}"
                        />

                        <!-- Receipt Date -->
                        <Text
                            text="{
								path: 'claim>RECEIPT_DATE',
								type: 'DateType',
								formatOptions: { pattern: 'dd MMM yyyy' }
							}"
                        />

                        <!-- Remarks -->
                        <Text text="{claim>REMARK}" />

                        <!-- Attachment 1 -->
                        <Link
                            press="onView_Claim_Attachment('child_t',null, $event)"
                            text="{claim>ATTACHMENT_FILE_1}"
                        />

                        <!-- Attachment 2 -->
                        <Link
                            press="onView_Claim_Attachment('child_t',null, $event)"
                            text="{claim>ATTACHMENT_FILE_2}"
                        />

                    </cells>
                </ColumnListItem>
            </items>
        </Table>
    </VBox>
</core:FragmentDefinition>
