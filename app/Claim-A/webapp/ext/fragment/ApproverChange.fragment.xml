<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <Dialog
        id="detailDialog"
        title="Modify Pending Approvers"
        contentWidth="60%"
    >
        <content>
            <Table
                id="popupTable"
                items="{
                    path: '/ZEMP_PENDING_LIST_APPROVER',
                    parameters: {
                        $select: 'ID,LEVEL,STATUS,APPROVER_ID,APPROVER_NAME',
                            $$updateGroupId: 'manualGroup'
                    }
                }"
            >
                <columns>
                    <Column width="4rem">
                        <Text text="Level" />
                    </Column>
                    <Column>
                        <Text text="Status" />
                    </Column>
                    <Column>
                        <Text text="Current Approver" />
                    </Column>
                    <Column>
                        <Text text="New Approver" />
                    </Column>
                </columns>
                <items>
                    <ColumnListItem>
                        <cells>
                            <Text text="{LEVEL}" />
                            <Text text="{STATUS_DESC}" />
                            <Text text="{APPROVER_NAME}" />
                            <Input
                                value="{NEW_APPROVER_ID}"
                                showValueHelp="true"
                                valueHelpRequest="onApproverValueHelpRequest"
                            />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
        <beginButton>
            <Button
                text="Save Changes"
                type="Emphasized"
                press=".onSaveApprovers"
            />
        </beginButton>
        <endButton>
            <Button
                text="Cancel"
                press=".onCloseDialog"
            />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
