<mvc:View
    controllerName="claima.controller.App"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:tnt="sap.tnt"
    xmlns:cards="sap.f.cards"
    xmlns:f="sap.f"
    xmlns:l="sap.ui.layout"
    xmlns:cssgrid="sap.ui.layout.cssgrid"
    xmlns:w="sap.ui.integration.widgets"
    xmlns:card="sap.f.cards"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
>
    <Page showHeader="false">
        <content>
            <ScrollContainer
                id="dashboard"
                horizontal="false"
                height="100%"
            >
                <VBox width="100%">
                    <HBox>
                        <Panel
                            width="100%"
                            height="4rem"
                            class="sapUiSmallMarginBeginEnd sapUiMediumMarginTopBottom"
                        >
                            <HBox>
                                <core:Icon
                                    src="sap-icon://document-text"
                                    size="25px"
                                />
                                <Title
                                    level="H3"
                                    text="{i18n>nav_myreport}"
                                    textAlign="Center"
                                    class="sapUiSmallMarginBegin"
                                />
                                <Title
                                    level="H3"
                                    text="{= ${dashboardModel>/claims}.length}"
                                    textAlign="Center"
                                    class="sapUiSmallMarginBegin"
                                />
                            </HBox>
                        </Panel>
                        <Panel
                            width="90%"
                            height="4rem"
                            class="sapUiMediumMarginBeginEnd sapUiMediumMarginTopBottom"
                        >
                            <HBox>
                                <core:Icon
                                    src="sap-icon://activity-items"
                                    size="25px"
                                />
                                <Title
                                    level="H3"
                                    text="{i18n>nav_preappstatus}"
                                    textAlign="Center"
                                    class="sapUiSmallMarginBegin"
                                />
                                <Title
                                    level="H3"
                                    text="{= ${dashboardModel>/requests}.length}"
                                    textAlign="Center"
                                    class="sapUiSmallMarginBegin"
                                />
                            </HBox>
                        </Panel>

                        <Panel
                            width="120%"
                            height="4rem"
                            class="sapUiMediumMarginBeginEnd sapUiMediumMarginTopBottom"
                        >
                            <HBox>
                                <core:Icon
                                    src="sap-icon://sys-enter"
                                    size="25px"
                                />
                                <Title
                                    level="H3"
                                    text="{i18n>approval}"
                                    textAlign="Center"
                                    class="sapUiSmallMarginBegin"
                                />
                                <Title
                                    level="H3"
                                    text="{= ${dashboardModel>/approvals}.length }"
                                    textAlign="Center"
                                    class="sapUiSmallMarginBegin"
                                />
                            </HBox>
                        </Panel>
                    </HBox>

                    <VBox>
                        <Panel
                            width="80%"
                            height="200px"
                            class="sapUiSmallMarginBeginEnd sapUiSmallMarginTopBottom"
                        >
                            <headerToolbar>
                                <OverflowToolbar
                                    design="Transparent"
                                    class="myCardHeaderSticky"
                                    width="100%"
                                >
                                    <core:Icon
                                        src="sap-icon://document-text"
                                        size="25px"
                                    />
                                    <Title
                                        level="H3"
                                        text="{i18n>myexpensesreport} ({= ${dashboardModel>/claims}.length})"
                                        textAlign="Center"
                                        class="sapUiSmallMarginBegin"
                                    />
                                    <ToolbarSpacer />
                                    <Button
                                        id="dashboard-claim"
                                        text="See All"
                                        class="sapUiLargeMarginBegin"
                                        type="Transparent"
                                        press="onClickNavigate"
                                    />
                                </OverflowToolbar>
                            </headerToolbar>
                            <VBox>
                                <ScrollContainer
                                    height="140px"
                                    vertical="true"
                                    horizontal="false"
                                >
                                    <Table
                                        id="claimtable"
                                        items="{dashboardModel>/claims}"
                                        sticky="HeaderToolbar,ColumnHeaders"
                                        noDataText="No data available"
                                        mode="SingleSelectMaster"
                                        inset="false"
                                        fixedLayout="true"
                                        itemPress="onRowPress"
                                    >
                                        <columns>
                                            <Column demandPopin="true">
                                                <header>
                                                    <Text text="{i18n>claim_id }" />
                                                </header>
                                            </Column>
                                            <Column demandPopin="true">
                                                <header>
                                                    <Text text="{i18n>label_claimdetails_input_}" />
                                                </header>
                                            </Column>
                                            <Column demandPopin="true">
                                                <header>
                                                    <Text text="{i18n>label_claimdetails_input_startdate}" />
                                                </header>
                                            </Column>
                                            <!-- <Column
                                                demandPopin="true" hAlign="End"
                                            >
                                                <header>
                                                    <Text
                                                        text="Amount(MYR)"
                                                        textAlign="Center"
                                                        width="100%"
                                                    />
                                                </header>
                                            </Column> -->
                                            <Column hAlign="End">
                                                <header>
                                                    <HBox
                                                        justifyContent="SpaceBetween"
                                                        alignItems="End"
                                                        width="100%"
                                                    >
                                                        <Text
                                                            text="{i18n>columntext_claimsummary_amt}"
                                                        />
                                                    </HBox>
                                                </header>
                                            </Column>
                                            <!-- <Column hAlign="End">
                                                <header>
                                                    <HBox
                                                        justifyContent="SpaceBetween"
                                                        alignItems="Center"
                                                        width="50%"
                                                    >
                                                        <Text
                                                            text="Amount (MYR)"
                                                        />
                                                    </HBox>
                                                </header>
                                            </Column> -->
                                            <Column demandPopin="true">
                                                <header>
                                                    <Text text="Status" />
                                                </header>
                                            </Column>
                                            <Column demandPopin="true">
                                                <header>
                                                    <Text
                                                        text="{i18n>lastmodified}"
                                                    />
                                                </header>
                                            </Column>
                                        </columns>
                                        <items>
                                            <ColumnListItem type="Active">
                                                <cells>
                                                    <Text
                                                        text="{dashboardModel>CLAIM_ID}"
                                                    />
                                                    <Text
                                                        text="{dashboardModel>PURPOSE}"
                                                    />
                                                    <Text
                                                        text="{ path: 'dashboardModel>TRIP_START_DATE',
                                                        type: 'sap.ui.model.odata.type.Date',
                                                        formatOptions: { pattern: 'dd MMM yyyy'} }"
                                                    />
                                                    <Text
                                                        textAlign="End"
                                                        text="{dashboardModel>TOTAL_CLAIM_AMOUNT}"
                                                    />
                                                    <Text
                                                        text="{dashboardModel>STATUS_DESC}"
                                                    />
                                                    <Text
                                                        text="{dashboardModel>modifiedAt}"
                                                    />
                                                </cells>
                                            </ColumnListItem>
                                        </items>
                                    </Table>
                                </ScrollContainer>
                            </VBox>
                        </Panel>
                    </VBox>

                    <VBox>
                        <Panel
                            width="80%"
                            height="200px"
                            class="sapUiSmallMarginBeginEnd sapUiTinyMarginTopBottom"
                        >
                            <headerToolbar>
                                <OverflowToolbar
                                    design="Transparent"
                                    class="myCardHeaderSticky"
                                    width="100%"
                                >
                                    <core:Icon
                                        src="sap-icon://activity-items"
                                        size="25px"
                                    />
                                    <Title
                                        level="H3"
                                        text="{i18n>myrequest} ({= ${dashboardModel>/requests}.length})"
                                        textAlign="Center"
                                        class="sapUiSmallMarginBegin"
                                    />
                                    <ToolbarSpacer />
                                    <Button
                                        id="dashboard-request"
                                        text="See All"
                                        class="sapUiLargeMarginBegin"
                                        type="Transparent"
                                        press="onClickNavigate"
                                    />
                                </OverflowToolbar>
                            </headerToolbar>
                            <VBox>
                                <ScrollContainer
                                    height="140px"
                                    vertical="true"
                                    horizontal="false"
                                >
                                    <Table
                                        items="{dashboardModel>/requests}"
                                        growing="true"
                                        sticky="HeaderToolbar,ColumnHeaders"
                                        noDataText="No data available"
                                        mode="SingleSelectMaster"
                                        itemPress="openItemFromList"
                                    >
                                        <columns>
                                            <Column demandPopin="true">
                                                <header>
                                                    <Text text="{i18n>requestid}" />
                                                </header>
                                            </Column>
                                            <Column demandPopin="true">
                                                <header>
                                                    <Text text="{i18n>label_claimdetails_input_purpose}" />
                                                </header>
                                            </Column>
                                            <Column demandPopin="true">
                                                <header>
                                                    <Text text="{i18n>label_claimdetails_input_startdate}" />
                                                </header>
                                            </Column>
                                            <!-- <Column demandPopin="true">
                                                <header>
                                                    <Text
                                                        text="Amount(MYR)"
                                                        textAlign="Center"
                                                        width="100%"
                                                    />
                                                </header>
                                            </Column> -->
                                            <Column hAlign="End">
                                                <header>
                                                    <HBox
                                                        justifyContent="SpaceBetween"
                                                        alignItems="End"
                                                        width="100%"
                                                    >
                                                        <Text
                                                            text="{i18n>columntext_claimsummary_amt}"
                                                        />
                                                    </HBox>
                                                </header>
                                            </Column>
                                            <Column demandPopin="true">
                                                <header>
                                                    <Text text="{i18n>appr_status}" />
                                                </header>
                                            </Column>
                                            <Column demandPopin="true">
                                                <header>
                                                    <Text
                                                        text="{i18n>lastmodified}"
                                                    />
                                                </header>
                                            </Column>
                                        </columns>
                                        <items>
                                            <ColumnListItem type="Active">
                                                <cells>
                                                    <Text
                                                        text="{dashboardModel>REQUEST_ID}"
                                                    />
                                                    <Text
                                                        text="{dashboardModel>OBJECTIVE_PURPOSE}"
                                                    />
                                                    <Text
                                                        text="{path: 'dashboardModel>REQUEST_DATE', 
                                                        type: 'sap.ui.model.odata.type.Date',
                                                        formatOptions: { pattern: 'dd MMM yyyy'} }"
                                                    />
                                                    <Text
                                                        text="{dashboardModel>PREAPPROVAL_AMOUNT}"
                                                    />
                                                    <Text
                                                        text="{dashboardModel>STATUS_DESC}"
                                                    />
                                                    <Text
                                                        text="{dashboardModel>modifiedAt}"
                                                    />
                                                </cells>
                                            </ColumnListItem>
                                        </items>
                                    </Table>
                                </ScrollContainer>
                            </VBox>
                        </Panel>
                    </VBox>

                    <VBox>
                        <Panel
                            width="80%"
                            height="200px"
                            class="sapUiSmallMarginBeginEnd sapUiTinyMarginTopBottom"
                        >
                            <headerToolbar>
                                <OverflowToolbar
                                    design="Transparent"
                                    class="myCardHeaderSticky"
                                    width="100%"
                                >
                                    <core:Icon
                                        src="sap-icon://sys-enter"
                                        size="25px"
                                    />
                                    <Title
                                        level="H3"
                                        text="{i18n>approval} ({= ${dashboardModel>/approvals}.length })"
                                        textAlign="Center"
                                        class="sapUiSmallMarginBegin"
                                    />
                                    <ToolbarSpacer />
                                    <Button
                                        id="dashboard-approval"
                                        text="See All"
                                        class="sapUiLargeMarginBegin"
                                        type="Transparent"
                                        press="onClickNavigate"
                                    />
                                </OverflowToolbar>
                            </headerToolbar>
                            <VBox>
                                <ScrollContainer
                                    height="140px"
                                    vertical="true"
                                    horizontal="false"
                                >
                                    <Table
                                        items="{dashboardModel>/approvals}"
                                        growing="true"
                                        sticky="HeaderToolbar,ColumnHeaders"
                                        noDataText="No data available"
                                    >
                                        <columns>
                                            <Column demandPopin="true">
                                                <header>
                                                    <Text
                                                        text="{i18n>claimrequestid}"
                                                    />
                                                </header>
                                            </Column>
                                            <Column demandPopin="true">
                                                <header>
                                                    <Text text="{i18n>label_claimdetails_input_purpose}" />
                                                </header>
                                            </Column>
                                            <Column demandPopin="true">
                                                <header>
                                                    <Text text="{i18n>label_claimdetails_input_startdate}" />
                                                </header>
                                            </Column>
                                            <!-- <Column demandPopin="true">
                                                <header>
                                                    <Text
                                                        text="Amount(MYR)"
                                                        textAlign="Center"
                                                        width="100%"
                                                    />
                                                </header>
                                            </Column> -->
                                            <Column hAlign="End">
                                                <header>
                                                    <HBox
                                                        justifyContent="SpaceBetween"
                                                        alignItems="End"
                                                        width="100%"
                                                    >
                                                        <Text
                                                            text="{i18n>columntext_claimsummary_amt}"
                                                        />
                                                    </HBox>
                                                </header>
                                            </Column>
                                            <Column demandPopin="true">
                                                <header>
                                                    <Text text="{i18n>appr_status}" />
                                                </header>
                                            </Column>
                                            <Column demandPopin="true">
                                                <header>
                                                    <Text
                                                        text="{i18n>lastmodified}"
                                                    />
                                                </header>
                                            </Column>
                                        </columns>
                                        <items>
                                            <ColumnListItem>
                                                <cells>
                                                    <Text
                                                        text="{dashboardModel>ID}"
                                                    />
                                                    <Text
                                                        text="{dashboardModel>PURPOSE}"
                                                    />
                                                    <Text
                                                        text="{path: 'dashboardModel>REQUEST_DATE',
                                                        type: 'sap.ui.model.odata.type.Date',
                                                        formatOptions: { pattern: 'dd MMM yyyy' }}"
                                                    />
                                                    <Text
                                                        textAlign="End"
                                                        text="{dashboardModel>AMOUNT}"
                                                    />
                                                    <Text
                                                        text="{dashboardModel>STATUS_DESC}"
                                                    />
                                                    <Text
                                                        text="{dashboardModel>modifiedAt}"
                                                    />
                                                </cells>
                                            </ColumnListItem>
                                        </items>
                                    </Table>
                                </ScrollContainer>
                            </VBox>
                        </Panel>
                    </VBox>
                </VBox>
            </ScrollContainer>
        </content>
    </Page>
</mvc:View>
