<mvc:View
    xmlns:table="sap.ui.table"
    xmlns:form="sap.ui.layout.form"
    xmlns:f="sap.f"
    height="100%"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    controllerName="claima.controller.RequestFormStatus"
    id="request_status_xmlview"
>
    <Page
        id="request_form_status"
        floatingFooter="true"
        showHeader="false"
    >
        <VBox class="roundedBox sapUiSmallMargin">
            <Table
                id="tb_myrequestform"
                headerText="{i18n>myrequeststatus_title}"
                mode="SingleSelectMaster"
                width="auto"
                items="{path: 'request_status>/req_header_list'}"
                itemPress="openItemFromList"
                growing="true"
            >
                <headerToolbar>
                    <Toolbar>
                        <Title
                            text="{= ${i18n>nav_myrequest} + ' (' + ${request_status>/req_header_count} + ')'}"
                        />
                        <ToolbarSpacer />
                        <Button
                            text="{i18n>myrequeststatus_sort_reset}"
                            type="Transparent"
                            icon="sap-icon://refresh"
                            press="onResetSort"
                        />
                        <Button type="Transparent" icon="sap-icon://action-settings" tooltip="Filter" press="onOpenFilterDialog"/>
                    </Toolbar>
                </headerToolbar>

                <columns>
                    <!-- REQUEST_ID -->
                    <Column>
                        <header>
                            <HBox
                                justifyContent="SpaceBetween"
                                alignItems="Center"
                                width="100%"
                            >
                                <Text text="{i18n>myrequeststatus_requestid}" />
                                <Button
                                    type="Transparent"
                                    icon="sap-icon://sort"
                                    tooltip="{i18n>myrequeststatus_sort_requestid}"
                                    press="onSortToggle"
                                >
                                    <customData>
                                        <core:CustomData
                                            key="path"
                                            value="REQUEST_ID"
                                        />
                                    </customData>
                                </Button>
                            </HBox>
                        </header>
                    </Column>

                    <!-- CLAIM_TYPE -->
                    <Column>
                        <header>
                            <HBox
                                justifyContent="SpaceBetween"
                                alignItems="Center"
                                width="100%"
                            >
                                <Text text="{i18n>myrequeststatus_claimtype}" />
                                <Button
                                    type="Transparent"
                                    icon="sap-icon://sort"
                                    tooltip="{i18n>myrequeststatus_sort_claimtype}"
                                    press="onSortToggle"
                                >
                                    <customData>
                                        <core:CustomData
                                            key="path"
                                            value="CLAIM_TYPE_DESC"
                                        />
                                    </customData>
                                </Button>
                            </HBox>
                        </header>
                    </Column>  

                    <!-- OBJECTIVE_PURPOSE -->
                    <Column>
                        <header>
                            <HBox
                                justifyContent="SpaceBetween"
                                alignItems="Center"
                                width="100%"
                            >
                                <Text text="{i18n>myrequeststatus_purpose}" />
                                <Button
                                    type="Transparent"
                                    icon="sap-icon://sort"
                                    tooltip="{i18n>myrequeststatus_sort_purpose}"
                                    press="onSortToggle"
                                >
                                    <customData>
                                        <core:CustomData
                                            key="path"
                                            value="OBJECTIVE_PURPOSE"
                                        />
                                    </customData>
                                </Button>
                            </HBox>
                        </header>
                    </Column>                    

                    <!-- REQUEST_DATE -->
                    <Column>
                        <header>
                            <HBox
                                justifyContent="SpaceBetween"
                                alignItems="Center"
                                width="100%"
                            >
                                <Text text="{i18n>myrequeststatus_startd}" />
                                <Button
                                    type="Transparent"
                                    icon="sap-icon://sort"
                                    tooltip="{i18n>myrequeststatus_sort_startd}"
                                    press="onSortToggle"
                                >
                                    <customData>
                                        <core:CustomData
                                            key="path"
                                            value="REQUEST_DATE"
                                        />
                                    </customData>
                                </Button>
                            </HBox>
                        </header>
                    </Column>

                    <!-- PREAPPROVAL_AMOUNT -->
                    <Column hAlign="End">
                        <header>
                            <HBox
                                justifyContent="SpaceBetween"
                                alignItems="Center"
                                width="70%"
                            >
                                <Text text="{i18n>myrequeststatus_amount}" />
                                <Button
                                    type="Transparent"
                                    icon="sap-icon://sort"
                                    tooltip="{i18n>myrequeststatus_sort_amount}"
                                    press="onSortToggle"
                                >
                                    <customData>
                                        <core:CustomData
                                            key="path"
                                            value="PREAPPROVAL_AMOUNT"
                                        />
                                    </customData>
                                </Button>
                            </HBox>
                        </header>
                    </Column>

                    <!-- STATUS_DESC -->
                    <Column>
                        <header>
                            <HBox
                                justifyContent="SpaceBetween"
                                alignItems="Center"
                                width="100%"
                            >
                                <Text text="{i18n>myrequeststatus_status}" />
                                <Button
                                    type="Transparent"
                                    icon="sap-icon://sort"
                                    tooltip="{i18n>myrequeststatus_sort_status}"
                                    press="onSortToggle"
                                >
                                    <customData>
                                        <core:CustomData
                                            key="path"
                                            value="STATUS_DESC"
                                        />
                                    </customData>
                                </Button>
                            </HBox>
                        </header>
                    </Column>

                     <!-- modifiedAt -->
                    <Column>
                        <header>
                            <HBox
                                justifyContent="SpaceBetween"
                                alignItems="Center"
                                width="100%"
                            >
                                <Text text="{i18n>myrequeststatus_lastmod}" />
                                <Button
                                    type="Transparent"
                                    icon="sap-icon://sort"
                                    tooltip="{i18n>myrequeststatus_sort_lastmod}"
                                    press="onSortToggle"
                                >
                                    <customData>
                                        <core:CustomData
                                            key="path"
                                            value="modifiedAt"
                                        />
                                    </customData>
                                </Button>
                            </HBox>
                        </header>
                    </Column>
                </columns>

                <!-- items unchanged -->
                <items>
                    <ColumnListItem type="Active">
                        <cells>
                            <Text text="{request_status>REQUEST_ID}" />
                            <Text text="{request_status>CLAIM_TYPE_DESC}" />
                            <Text text="{request_status>OBJECTIVE_PURPOSE}" />
                            <Text
                                text="{
                                    path: 'request_status>REQUEST_DATE',
                                    type: 'sap.ui.model.odata.type.Date',
                                    formatOptions: { pattern: 'dd MMM yyyy' } 
                                }"
                            />                            
                            <Text
                                text="{
                                    path: 'request_status>PREAPPROVAL_AMOUNT',
                                    type: 'sap.ui.model.type.Float',
                                    formatOptions: { minFractionDigits: 2, maxFractionDigits: 2 }
                                }"
                            />
                            <Text text="{request_status>STATUS_DESC}" />
                            <Text text="{ 
                                        path: 'request_status>modifiedAt',
                                        formatter: '.formatter.convertUTCToLocal' 
                                    }"
                            />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </VBox>
    </Page>
</mvc:View>
