<mvc:View
    controllerName="claima.controller.ManageSub"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:mdc="sap.ui.mdc"
    xmlns:mdcvh="sap.ui.mdc.valuehelp"
    xmlns:mdcvhcnt="sap.ui.mdc.valuehelp.content"
    xmlns:f="sap.f"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    id="addSub_xmlview">

    <Page id="page" showHeader="false">
        <content>
            <VBox class= "roundedBox sapUiSmallMargin">
            <Table id="tblSubs"
                   mode="SingleSelectMaster"
                   includeItemInSelection="true"
                   selectionChange=".onSelectionChange"
                   width="auto"
                   growing="true"
                   noDataText="{i18n>noData}"
                   items="{
                     path: '/ZSUBSTITUTION_RULES',
                     parameters: {
                       $orderby: 'VALID_FROM desc'
                       , $expand: 'ZEMP_MASTER_SUBS',
                         $select: 'SUBSTITUTE_ID,VALID_FROM,VALID_TO,ZEMP_MASTER_SUBS/EMAIL,ZEMP_MASTER_SUBS/NAME'   
                     }
                   }">

                   <headerToolbar>
                        <Toolbar>
                            <Title
                                text="{i18n>ManageSubTitle}"/>
                        </Toolbar>
                    </headerToolbar>
                 
                 
                <columns>
                    <Column width="6rem"><Text text="{i18n>tableColumnID}" /></Column>
                    <Column width="15rem"><Text text="{i18n>tableColumnName}" /></Column>
                    <Column width="13rem"><Text text="{i18n>tableColumnEmail}" /></Column>
                    <Column width="12rem"><Text text="{i18n>tableColumnPeriod}" /></Column>
                    <Column width="10rem"><Text text="{i18n>tableColumnStart}" /></Column>
                    <Column width="10rem"><Text text="{i18n>tableColumnEnd}" /></Column>
                </columns>

                <items>
                    <ColumnListItem>
                        <cells>
                            <!-- Subsitute Column -->
                            <Text text="{SUBSTITUTE_ID}" />

                            <!--Substitute Name -->
                            <Text text="{ZEMP_MASTER_SUBS/NAME}" />

                            <!-- NEW: Email (from expanded nav property) -->
                            <Text text="{ZEMP_MASTER_SUBS/EMAIL}" />
    
                            <Text text="{
                            parts: ['VALID_FROM','VALID_TO'],
                            formatter: '.fmtPeriodMessage'
                            }"/>

                            <!-- Valid From -->
                            <Text text="{
                              path: 'VALID_FROM',
                              type: 'sap.ui.model.odata.type.Date',
                              formatOptions: { style: 'medium' }
                            }" />

                            <!-- Valid To -->
                            <Text text="{
                              path: 'VALID_TO',
                              type: 'sap.ui.model.odata.type.Date',
                              formatOptions: { style: 'medium' }
                            }" />

                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
            </VBox>
        </content>

        <footer>
            <OverflowToolbar>
                <ToolbarSpacer />
                <Button id="btnAdd"
                        type="Emphasized"
                        text="{i18n>addNew}"
                        press=".onAdd" 
                        visible="{vm>/isApprover}"/>
                <Button id="Deletebtn"
                        type="Transparent"
                        text="{i18n>delete}"
                        visible="{vm>/canDelete}"
                        press=".onDelete" />
            </OverflowToolbar>
        </footer>

        <!-- Value Help for Employee selection (EEID + Name).-->
        <dependents>
                <mdc:ValueHelp
                    id="valuehelp_managesub_emp"
                    delegate="{
                        name: 'claima/utils/ValueHelpDelegate_MngeSub',
                        payload: {
                            searchKeys: ['EEID', 'NAME', 'EMAIL'],
                            columns: [
                                'Employee ID',
                                'Name',
                                'Email'
                            ],
                            openOnClick: true
                        }
                    }">
                    <mdc:typeahead>
                        <mdcvh:Popover title="Select Employee">
                            <mdcvhcnt:MTable
                                keyPath="EEID"
                                descriptionPath="NAME"
                                caseSensitive="false"
                                useAsValueHelp="true"/>
                        </mdcvh:Popover>
                    </mdc:typeahead>
                    <mdc:dialog>
                    <mdcvh:Dialog title="Select Employee">
                        <mdcvhcnt:MTable
                            keyPath="EEID"
                            descriptionPath="NAME"
                            useAsValueHelp="true"/>
                            </mdcvh:Dialog>
                    </mdc:dialog>
                </mdc:ValueHelp>
            </dependents>

        <Dialog id="dlgAdd" title="{i18n>addDlgTitle}" type="Message">
    <content>
        <VBox class="sapUiSmallMargin">

        <!-- <Label text="{i18n>enterUser}" labelFor="inpUser"/> -->
        <Label text="Enter Employee ID or Email" labelFor="inpUser"/>

        <VBox class="sapUiMediumMarginBottom">
            <mdc:Field 
                id="inpUser"
                value="{vm>/subInput}"
                editMode="Editable"
                valueHelp="valuehelp_managesub_emp"
                liveChange=".onSubstituteIdChange"
                placeholder="Enter here "
                width="100%" />
            <!-- small space above the info line; -->
            <Text text="{vm>/subInfo}"
                visible="{= !!${vm>/subInfo} }" 
                 class="sapUiTinyMarginTop"/>
        </VBox>

        <Label text="{i18n>tableColumnPeriod}" />
        
        <DateRangeSelection
            id="drs"
            displayFormat="medium"
            valueFormat="yyyy-MM-dd"
            placeholder="{i18n>periodPlaceholder}"
            minDate="{vm>/todayDate}" />
        </VBox>
    </content>

    <beginButton>
        <Button text="{i18n>save}" type="Emphasized" press=".onSave" enabled="{vm>/subValid}"/>
    </beginButton>
    <endButton>
        <Button text="{i18n>cancel}" press=".onCancel"/>
    </endButton>
    </Dialog>
    </Page>
</mvc:View>