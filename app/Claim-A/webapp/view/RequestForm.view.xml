<mvc:View 
	height="100%"
    xmlns:form="sap.ui.layout.form" 
    xmlns:f="sap.f"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:unified="sap.ui.unified" 
    xmlns:columnmenu="sap.m.table.columnmenu" 
    xmlns:table="sap.ui.table" 
    xmlns:m="sap.m"
    xmlns:tnt="sap.tnt"
    xmlns:cards="sap.f.cards"
    xmlns:l="sap.ui.layout"
    xmlns:cssgrid="sap.ui.layout.cssgrid"
    xmlns:w="sap.ui.integration.widgets"
    xmlns:card="sap.f.cards"
    xmlns:Icon="sap.ui.core.Icon"
    xmlns:ShellBar="sap.f.ShellBar"
    xmlns:layout="sap.ui.layout"
    xmlns:mdc="sap.ui.mdc"
    xmlns:mdcvh="sap.ui.mdc.valuehelp"
    xmlns:mdcvhcnt="sap.ui.mdc.valuehelp.content"
	controllerName="claima.controller.RequestForm"
    id="request_form_xmlview">

    <Page  
        id="request_form"
        showHeader="false"
        floatingFooter="true"
        enableScrolling="true"
    >
        <footer>
            <OverflowToolbar>
                <ToolbarSpacer/>
                <!-- View Mode -->
                <Button id="req_back_scr"       type="Default"      text="{i18n>req_view_btn_back}"                     press=".onBackView"         visible="false" />

                <!-- Header Level -->
                <Button id="req_back"           type="Default"      text="{i18n>req_view_btn_back}"                     press=".onBack"             visible="false" />
                <Button id="req_delete"         type="Default"      text="{i18n>req_view_btn_delete}"           press=".onDeleteRequest"    visible="false" />
                <Button id="req_submit"         type="Emphasized"   text="{i18n>req_view_btn_submit}"           press=".onSubmitRequest"    visible="false" />

                <!-- Item Level --> 
                <Button id="req_item_cancel"    type="Default"      text="{i18n>req_view_btn_cancel}"                   press=".onCancelItem"       visible="false" />
                <Button id="req_item_save"      type="Default"      text="{i18n>req_view_btn_save}"                     press=".onSaveItem"         visible="false" />

                <!-- Approver -->
                <Button id="req_reject"         type="Default"      text="{i18n>req_view_btn_reject}"                   press=".onRejectRequest"    visible="false" />
                <Button id="req_send_back"      type="Default"      text="{i18n>req_view_btn_pushback}"                press=".onSendBackRequest"  visible="false" />
                <Button id="req_approve"        type="Emphasized"   text="{i18n>req_view_btn_approve}"                  press=".onApproveRequest"   visible="false" />
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>