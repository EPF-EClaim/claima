<mvc:View 
	height="100%"
    xmlns:form="sap.ui.layout.form" 
    xmlns:f="sap.f"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:unified="sap.ui.unified" 
    xmlns:columnmenu="sap.m.table.columnmenu" 
    xmlns:table="sap.ui.table" 
    xmlns:m="sap.m"
    xmlns:tnt="sap.tnt"
    xmlns:cards="sap.f.cards"
    xmlns:l="sap.ui.layout"
    xmlns:cssgrid="sap.ui.layout.cssgrid"
    xmlns:w="sap.ui.integration.widgets"
    xmlns:card="sap.f.cards"
    xmlns:Icon="sap.ui.core.Icon"
    xmlns:ShellBar="sap.f.ShellBar"
    xmlns:layout="sap.ui.layout"
    xmlns:mdc="sap.ui.mdc"
    xmlns:mdcvh="sap.ui.mdc.valuehelp"
    xmlns:mdcvhcnt="sap.ui.mdc.valuehelp.content"
	controllerName="claima.controller.RequestForm"
    id="request_form_xmlview">

    <Page  
        id="request_form"
        showHeader="false"
        floatingFooter="true"
        enableScrolling="true"
    >
        <content>
            <VBox >
                <VBox
                    id="request_form_header_box1" 
                    backgroundDesign="Solid"
                    class="roundedBox sapUiSmallMargin sapUiTinyMarginBottom"
                    rowGap="1rem">
                    <OverflowToolbar height="3rem">
                        <Title text="{i18n>req_form_header_title}"/>
                        <ToolbarSpacer/>
                        <Button
                            type="Default"
                            icon="sap-icon://excel-attachment"
                            text="{i18n>downloaddetails}"
                            id="PARDownloadExcelBtn"
                            press=".onDownloadExcelReport"
                        />

                        <!-- Save header -->
                        <Button
                            type="Default"
                            icon="sap-icon://save"
                            text="{i18n>req_view_btn_save}"
                            id="btnSaveHeader"
                            press=".onSaveHeaderPress"
                            visible="{reqHeaderEditableModel>/saveHeader}"
                        />
                    </OverflowToolbar>
                    <form:Form 
                        id="req_header1"
                        layout="ColumnLayout"
                        editable="false" >
                        <form:layout><form:ColumnLayout columnsL="2" columnsM="2" /></form:layout>
                        <form:formContainers>
                            <form:FormContainer >
                                <form:formElements>
                                    <form:FormElement label="{i18n>req_purpose}"><form:fields><Text text="{request>/req_header/purpose}" /></form:fields></form:FormElement>
                                    <form:FormElement label="{i18n>req_id}"><form:fields><Text text="{request>/req_header/reqid}" /></form:fields></form:FormElement>
                                    <form:FormElement label="{i18n>req_tripstartdate}"><form:fields><DatePicker value="{request>/req_header/tripstartdate}" required="true" editable="{reqHeaderEditableModel>/startTrip}"/></form:fields></form:FormElement>
                                    <form:FormElement label="{i18n>req_tripenddate}"><form:fields><DatePicker value="{request>/req_header/tripenddate}" required="true" editable="{reqHeaderEditableModel>/endTrip}"/></form:fields></form:FormElement>
                                    <form:FormElement label="{i18n>req_eventstartdate}"><form:fields><DatePicker value="{request>/req_header/eventstartdate}" 
                                                                                                                 required="{reqHeaderEditableModel>/startEventRequired}"
                                                                                                                 editable="{reqHeaderEditableModel>/startEvent}"    
                                    /></form:fields></form:FormElement>
                                    <form:FormElement label="{i18n>req_eventenddate}"><form:fields><DatePicker value="{request>/req_header/eventenddate}" 
                                                                                                               required="{reqHeaderEditableModel>/endEventRequired}" 
                                                                                                               editable="{reqHeaderEditableModel>/endEvent}"                  
                                    /></form:fields></form:FormElement>
                                    <form:FormElement label="{i18n>req_location}"><form:fields><Input value="{request>/req_header/location}" editable="{reqHeaderEditableModel>/location}"/></form:fields></form:FormElement>
                                    <form:FormElement label="{i18n>req_grptype}"><form:fields><Text text="{request>/req_header/grptype}" /></form:fields></form:FormElement>
                                    <form:FormElement label="{i18n>req_transport}"><form:fields><Text text="{request>/req_header/transport}" /></form:fields></form:FormElement>
                                    <form:FormElement label="{i18n>req_status}"><form:fields><Text text="{request>/req_header/reqstatus}" /></form:fields></form:FormElement>
                                    <form:FormElement label="{i18n>req_cc}"><form:fields><Text text="{request>/req_header/costcenter}"/></form:fields></form:FormElement>
                                    <form:FormElement label="{i18n>req_acc}"><form:fields>                              
                                        <mdc:Field
                                            id="req_alt_cost_center"
                                            value="{request>/req_header/altcostcenter}"
                                            additionalValue="{request>/req_header/altcostcenterdesc}"
                                            editMode="{= ${reqHeaderEditableModel>/altCostCenter} ? 'Editable' : 'Display' }"
                                            display="ValueDescription"
                                            valueHelp="valuehelp_req_altcc"
                                        />
                                    </form:fields></form:FormElement>
                                    <form:FormElement label="{i18n>req_caa}">
                                        <form:fields><Text text="{
                                                path: 'request>/req_header/cashadvamt',
                                                type: 'sap.ui.model.type.Float',
                                                formatOptions: {
                                                    minFractionDigits: 2,
                                                    maxFractionDigits: 2,
                                                    groupingEnabled: true
                                                }}" 
                                            textDirection="RTL"></Text></form:fields>
                                    </form:FormElement>
                                    <form:FormElement label="{i18n>req_amt}">
                                        <form:fields><Text text="{
                                                path: 'request>/req_header/reqamt',
                                                type: 'sap.ui.model.type.Float',
                                                formatOptions: {
                                                    minFractionDigits: 2,
                                                    maxFractionDigits: 2,
                                                    groupingEnabled: true
                                                }}" 
                                            textDirection="RTL"></Text></form:fields>
                                    </form:FormElement>
                                    <form:FormElement label="{i18n>req_rtype}"><form:fields><Text text="{request>/req_header/reqtype}" /></form:fields></form:FormElement>
                                    <form:FormElement label="{i18n>req_comment}"><form:fields><Input value="{request>/req_header/comment}" editable="{reqHeaderEditableModel>/comment}"/></form:fields></form:FormElement>
                                    <form:FormElement label="{i18n>req_attach1}"><form:fields><Link id="attachment1" press="onDocLinkPress" text="{request>/req_header/doc1}"/></form:fields></form:FormElement>
                                    <form:FormElement label="{i18n>req_attach2}"><form:fields><Link id="attachment2" press="onDocLinkPress" text="{request>/req_header/doc2}"/></form:fields></form:FormElement>
                                    <form:FormElement label="{i18n>req_claimtype}"><form:fields><Text text="{request>/req_header/claimtypedesc}"/></form:fields></form:FormElement>
                                </form:formElements>
                            </form:FormContainer>
                        </form:formContainers>
                    </form:Form>
                    <dependents>
                            <mdc:ValueHelp
                                id="valuehelp_req_altcc"
                                delegate='{
                                    "name": "claima/utils/ValueHelpDelegate_Common",
                                    "payload": {
                                        "modelName": "employee",
                                        "entitySet": "employee>/ZCOST_CENTER",
                                        "keyField": "COST_CENTER_ID",
                                        "descriptionField": "COST_CENTER_DESC",
                                        "columns": [
                                            "{i18n>valuehelp_claiminput_altcc_col_id}",
                                            "{i18n>valuehelp_claiminput_altcc_col_name}"
                                        ],
                                        "searchKeys": ["COST_CENTER_ID", "COST_CENTER_DESC"],
                                        "openOnClick": true
                                    }
                                }'
                            >
                                <mdc:typeahead>
                                    <mdcvh:Popover>
                                        <mdcvhcnt:MTable
                                            keyPath="COST_CENTER_ID"
                                            descriptionPath="COST_CENTER_DESC"
                                            caseSensitive="false"
                                            useAsValueHelp="false" />
                                    </mdcvh:Popover>
                                </mdc:typeahead>

                                <mdc:dialog>
                                    <mdcvh:Dialog title="{i18n>valuehelp_claiminput_altcc}">
                                        <mdcvhcnt:MTable
                                            keyPath="COST_CENTER_ID"
                                            descriptionPath="COST_CENTER_DESC"
                                            caseSensitive="false" />
                                    </mdcvh:Dialog>
                                </mdc:dialog>
                            </mdc:ValueHelp>
                        </dependents>
                </VBox>
            </VBox>
        </content>
        <footer>
            <OverflowToolbar>
                <ToolbarSpacer/>
                <!-- View Mode -->
                <Button id="req_back_scr"       type="Default"      text="{i18n>req_view_btn_back}"                     press=".onBackView"         visible="false" />

                <!-- Header Level -->
                <Button id="req_back"           type="Default"      text="{i18n>req_view_btn_back}"                     press=".onBack"             visible="false" />
                <Button id="req_delete"         type="Default"      text="{i18n>req_view_btn_delete}"           press=".onDeleteRequest"    visible="false" />
                <Button id="req_submit"         type="Emphasized"   text="{i18n>req_view_btn_submit}"           press=".onSubmitRequest"    visible="false" />

                <!-- Item Level --> 
                <Button id="req_item_cancel"    type="Default"      text="{i18n>req_view_btn_cancel}"                   press=".onCancelItem"       visible="false" />
                <Button id="req_item_save"      type="Default"      text="{i18n>req_view_btn_save}"                     press=".onSaveItem"         visible="false" />

                <!-- Approver -->
                <Button id="req_reject"         type="Default"      text="{i18n>req_view_btn_reject}"                   press=".onRejectRequest"    visible="false" />
                <Button id="req_send_back"      type="Default"      text="{i18n>req_view_btn_pushback}"                press=".onSendBackRequest"  visible="false" />
                <Button id="req_approve"        type="Emphasized"   text="{i18n>req_view_btn_approve}"                  press=".onApproveRequest"   visible="false" />
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>