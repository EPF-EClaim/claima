<mvc:View
    controllerName="claima.controller.SendingIS"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    id="addIS_xmlview">
    <App id="app">
        <Page title="DB View → CAP → IS (No Email Fields)">
            <content>
                <VBox class="sapUiSmallMargin">
                    <Table id="idClaimTable"
                           mode="SingleSelectLeft"
                           items="{
                               path: '/ClaimSubmissionView',
                               parameters: { $count: true }
                           }">
                        <columns>
                            <Column width="10rem">
                                <Text text="CLAIM_ID"/>
                            </Column>
                            <Column width="12rem">
                                <Text text="CLAIM_SUB_ID"/>
                            </Column>
                            <Column width="10rem">
                                <Text text="EMP_ID"/>
                            </Column>
                            <Column width="12rem">
                                <Text text="SUBMISSION_TYPE"/>
                            </Column>
                            <Column width="10rem">
                                <Text text="AMOUNT"/>
                            </Column>
                            <Column width="12rem">
                                <Text text="SUBMITTED_DATE"/>
                            </Column>
                        </columns>
                        <items>
                            <ColumnListItem>
                                <cells>
                                    <ObjectIdentifier title="{CLAIM_ID}"/>
                                    <Text text="{CLAIM_SUB_ID}"/>
                                    <Text text="{EMP_ID}"/>
                                    <Text text="{SUBMISSION_TYPE}"/>
                                    <Text text="{AMOUNT}"/>
                                    <Text text="{SUBMITTED_DATE}"/>
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                    <Toolbar style="Clear">
                        <ToolbarSpacer/>
                        <Button text="Send to IS"
                                type="Emphasized"
                                press=".onSendToIS"/>
                    </Toolbar>
                </VBox>
            </content>
        </Page>
    </App>
</mvc:View>
