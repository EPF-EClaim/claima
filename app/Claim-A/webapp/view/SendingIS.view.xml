
<mvc:View
    controllerName="claima.controller.SendingIS"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

  <App id="app">
    <Page title="Send Claim / Pre‑Approval to IS">
      <content>
        <VBox class="sapUiLargeMargin">
          <HBox>
            <SearchField id="claimIdField" width="25rem" placeholder="Enter REQ... or CLM..."/>
            <Button text="Send by ID" type="Emphasized" press=".onSendByIdSmart" class="sapUiSmallMarginBegin"/>
          </HBox>
        </VBox>
      </content>
    </Page>
  </App>
</mvc:View>
