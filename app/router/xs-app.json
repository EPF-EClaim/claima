{
  "welcomeFile": "/claima/index.html",
  "authenticationMethod": "route",
  "logout": {
    "logoutEndpoint": "/do/logout",
    "logoutPage": "/index.html"
  },
  "sessionTimeout": 20,
  "routes": [
    {
      "source": "^/$",
      "target": "/",
      "authenticationType": "xsuaa"
    },
    {
      "source": "^/user-api/currentUser$",
      "target": "/currentUser",
      "service": "sap-approuter-userapi",
      "authenticationType": "xsuaa" 
    },
    {
      "source": "^/claima/(.*)$",
      "target": "/claima/$1",
      "localDir": "resources", 
      "authenticationType": "xsuaa"
    },
    {
      "source": "/http/(.*)$",
      "target": "/http/$1",
      "destination": "srv-api",
      "authenticationType": "xsuaa"
    },
    {
      "source": "^(?:/app|/app/.*)?/resources/(.*)$",
      "target": "/resources/$1",
      "authenticationType": "xsuaa",
      "destination": "srv-api"
    },
    {
      "source": "^(?:/app|/app/.*)?/test-resources/(.*)$",
      "target": "/test-resources/$1",
      "authenticationType": "xsuaa",
      "destination": "srv-api"
    },
    {
      "source": "^/SuccessFactors_API/(.*)$",
      "target": "/$1",
      "authenticationType": "basic",
      "csrfProtection": false,
      "destination": "Conn_SF_API"
    }
  ]
}