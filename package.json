{
  "name": "claima-backend",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@cap-js/hana": "^2.6.0",
    "@sap-cloud-sdk/connectivity": "^4",
    "@sap-cloud-sdk/http-client": "^4",
    "@sap-cloud-sdk/resilience": "^4",
    "@sap/approuter": "^20.10.0",
    "@sap/xssec": "^4",
    "cds": "^0.2.0",
    "express": "^4",
    "xlsx": "^0.18.5",
    "xml-js": "^1.6.11"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "@ui5/cli": "^4.0.45",
    "cds-plugin-ui5": "^0.13.0",
    "mbt": "^1.2.29",
    "rimraf": "^5.0.5",
    "ui5-tooling-modules": "^3.34.6"
  },
  "scripts": {
    "start": "cds-serve",
    "undeploy": "cf undeploy claima-backend --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1",
    "watch-claima": "cds watch --open claima/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "cds": {
    "server": {
      "index": true,
      "body_parser": {
        "limit": "10mb"
      }
    },
    "log": {
      "levels": {
        "auth": "debug"
      }
    },
    "fiori": {
      "lean_draft": true,
      "bypass_draft": true
    },
    "hana": {
      "deploy-format": "hdbtable"
    },
    "requires": {
      "IS_Conn": { 
        "kind": "odata",
        "credentials": {
          "destination": "IS_Conn"
        }
      },
      "[production]": {
        "db": "hana-cloud",
        "auth": "xsuaa"
      },
      "connectivity": true,
      "[hybrid]": {
        "db": "hana-cloud",
        "auth": {
          "kind": "mocked",
          "users": {
            "nur.ain.mohamad": {
              "password": "test123",
              "roles": [
                "Claimant"
              ]
            },
            "nurin.athirah@my.ey.com": {
              "password": "test123",
              "roles": [
                "DTD_Admin"
              ]
            }
          }
        }
      },
      "app-front": true,
      "html5-repo": true,
      "destinations": true
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/Claim-A"
  ]
}
