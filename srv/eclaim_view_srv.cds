                ZCLAIM_ITEM.ZPROFESIONAL_BODY.PROFESIONAL_BODY_DESC,
                ZCLAIM_ITEM.DISCLAIMER_GALAKAN,
                ZCLAIM_ITEM.TRANSFER_DATE,
