                ZCLAIM_ITEM.TO_STATE_ID,
                ZCLAIM_ITEM.ZTOSTATE.STATE_DESC                              as TO_STATE_DESC,
                ZCLAIM_ITEM.GL_ACCOUNT,
                ZCLAIM_ITEM.MATERIAL_CODE,
                ZREQUEST_HEADER.REQUEST_ID,
                ZREQUEST_HEADER.REQUEST_DATE,
                APPROVER1,
                APPROVER2,
